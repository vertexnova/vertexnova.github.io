---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---
<BaseLayout title="Research" description="Research notes on 3DGS, neural rendering, Vulkan ray tracing, and real-time graphics.">

<section class="section">
  <div class="container">
    <PageHeader
      eyebrow="Research"
      title="Neural Rendering and Real-Time Graphics"
      description="Focused notes on 3D Gaussian Splatting, GPU rendering workflows, and implementation constraints on DGX Spark."
    />

    <div class="notes-list">
      <a href="/research/roadmap" class="note-card card roadmap-card">
        <div class="note-meta">
          <span class="note-date">Current plan</span>
          <span class="tag orange" style="font-size:0.68rem">roadmap</span>
        </div>
        <h3 class="note-title">Research Roadmap</h3>
        <p class="note-desc">Four-phase plan from 3DGS foundations to Vulkan and medical visualization goals, with status by phase and next actions.</p>
      </a>

      <a href="/research/gsplat" class="note-card card">
        <div class="note-meta">
          <span class="note-date">Technical note</span>
          <span class="tag orange" style="font-size:0.68rem">gsplat</span>
        </div>
        <h3 class="note-title">gsplat on DGX Spark</h3>
        <p class="note-desc">Short practical guide: what gsplat is, how the rasterization pipeline works, API examples, and the verified DGX Spark install flow.</p>
      </a>
    </div>

  </div>
</section>

</BaseLayout>

<style>
.notes-list { display: flex; flex-direction: column; gap: 1rem; margin-top: 2rem; }
.note-card { display: block; text-decoration: none; }
.roadmap-card { border-color: var(--orange-dark); background: color-mix(in srgb, var(--panel) 92%, var(--orange-tint)); }
.note-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
.note-date { font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted); }
.note-title { color: var(--text); margin-bottom: 0.5rem; font-size: 1.1rem; }
.note-desc { font-size: 0.92rem; margin: 0; line-height: 1.7; color: var(--muted); }
</style>
