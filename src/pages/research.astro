---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getCollection } from 'astro:content';

const notes = await getCollection('research');
const active = notes.filter(n => n.data.status === 'active');
const drafts = notes.filter(n => n.data.status === 'draft');
---
<BaseLayout title="Research" description="Research notes on 3DGS, neural rendering, Vulkan ray tracing, and real-time graphics.">

<section class="section">
  <div class="container">
    <PageHeader
      eyebrow="Research"
      title="Neural Rendering and Real-Time Graphics"
      description="Focused notes on 3D Gaussian Splatting, GPU rendering workflows, and implementation constraints on DGX Spark."
    />

    <h2 class="section-label">Start Here</h2>
    <div class="notes-list">
      <a href="/research/roadmap" class="note-card card roadmap-card">
        <div class="note-meta">
          <span class="note-date">Current plan</span>
          <span class="tag orange" style="font-size:0.68rem">roadmap</span>
        </div>
        <h3 class="note-title">Research Roadmap</h3>
        <p class="note-desc">Four-phase plan from 3DGS foundations to Vulkan and medical visualization goals, with status by phase and next actions.</p>
      </a>
    </div>

    <h2 class="section-label">Published Notes</h2>
    <div class="notes-list">
      {active.map(n => (
        <a href={`/research/${n.id}`} class="note-card card">
          <div class="note-meta">
            <span class="note-date">{n.data.date}</span>
            <span class="tag orange" style="font-size:0.68rem">published</span>
          </div>
          <h3 class="note-title">{n.data.title}</h3>
          <p class="note-desc">{n.data.description}</p>
        </a>
      ))}
    </div>

    <h2 class="section-label">Planned Topics</h2>
    <div class="notes-list">
      {drafts.map(n => (
        <article class="note-card card draft">
          <div class="note-meta">
            <span class="note-date">{n.data.date}</span>
            <span class="tag" style="font-size:0.68rem">planned</span>
          </div>
          <h3 class="note-title">{n.data.title}</h3>
          <p class="note-desc">{n.data.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

</BaseLayout>

<style>
.section-label {
  font-family: var(--font-mono);
  font-size: 0.74rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--orange-light);
  margin-top: 2.5rem;
  margin-bottom: 0.75rem;
  padding-bottom: 0.35rem;
  border-bottom: 1px solid var(--border);
}
.notes-list { display: flex; flex-direction: column; gap: 1rem; }
.note-card { display: block; text-decoration: none; }
.roadmap-card { border-color: var(--orange-dark); background: color-mix(in srgb, var(--panel) 92%, var(--orange-tint)); }
.note-card.draft { opacity: 0.72; }
.note-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
.note-date { font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted); }
.note-title { color: var(--text); margin-bottom: 0.5rem; font-size: 1.1rem; }
.note-desc { font-size: 0.92rem; margin: 0; line-height: 1.7; color: var(--muted); }
</style>
