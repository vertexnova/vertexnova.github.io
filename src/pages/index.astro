---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SAMPLE_GROUPS } from '../data/samples';

const totalSamples = SAMPLE_GROUPS.flatMap(g => g.samples).length;
---

<BaseLayout
  title="WebGPU Samples"
  description="Live WebGPU samples from the VertexNova rendering engine — running in the browser via WebAssembly."
>

<section class="hero section">
  <div class="container">
    <div class="hero-eyebrow">
      <span class="tag orange">WebGPU · WebAssembly · C++20</span>
      <span class="tag">Emscripten · vnerhi</span>
    </div>
    <h1 class="hero-title">
      VertexNova<br/>
      <span class="accent">WebGPU Samples</span>
    </h1>
    <p class="hero-desc">
      {totalSamples} interactive rendering demos from the VertexNova RHI — compiled from C++20 to
      WebAssembly with Emscripten and running live in your browser via WebGPU.
      From a basic triangle to physically-based rendering, OIT, and medical volume rendering.
    </p>
    <div class="hero-actions">
      <a href="/samples" class="btn btn-primary">Launch Explorer →</a>
      <a href="/samples/support" class="btn btn-ghost">Browser support</a>
    </div>
  </div>
</section>

<div class="divider"></div>

<section class="section-sm">
  <div class="container">
    <div class="stats-row">
      <div class="stat">
        <span class="stat-num">{totalSamples}</span>
        <span class="stat-label">Live samples</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">{SAMPLE_GROUPS.length}</span>
        <span class="stat-label">Categories</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">C++20</span>
        <span class="stat-label">Source language</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">WGSL</span>
        <span class="stat-label">Shader language</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">6</span>
        <span class="stat-label">Target platforms</span>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<section class="section">
  <div class="container">
    <h2 class="section-heading">Sample categories</h2>
    <p class="section-sub">Select any category in the explorer to jump straight to those demos.</p>
    <div class="categories-grid">
      {SAMPLE_GROUPS.map(group => (
        <a href={`/samples#${group.samples[0].slug}`} class="cat-card card card-link">
          <div class="cat-count">{group.samples.length}</div>
          <h3>{group.label}</h3>
          <p>{group.samples.slice(0, 3).map(s => s.title).join(' · ')}{group.samples.length > 3 ? ' …' : ''}</p>
          <span class="card-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<section class="section">
  <div class="container">
    <div class="engine-strip">
      <div class="engine-text">
        <span class="tag orange" style="margin-bottom:1rem;display:inline-block">Open source · github.com/vertexnova</span>
        <h2>Built with VertexNova RHI</h2>
        <p style="margin-top:0.75rem">
          These samples are compiled from the same C++20 source that runs natively on Vulkan, Metal,
          and OpenGL across six platforms. The WebGPU backend targets the browser via Emscripten.
        </p>
        <div style="display:flex;gap:0.75rem;margin-top:1.5rem;flex-wrap:wrap">
          <a href="https://ajeetsinghyadav.github.io/engine" target="_blank" class="btn btn-primary">Engine docs ↗</a>
          <a href="https://github.com/vertexnova/vnerhi" target="_blank" class="btn btn-ghost">Source code ↗</a>
        </div>
      </div>
      <div class="tech-stack">
        <span class="tag">C++20</span>
        <span class="tag">WebGPU</span>
        <span class="tag">WGSL</span>
        <span class="tag">Emscripten</span>
        <span class="tag">WebAssembly</span>
        <span class="tag">Vulkan</span>
        <span class="tag">Metal</span>
        <span class="tag">SPIRV-Cross</span>
        <span class="tag">CMake</span>
        <span class="tag">pthreads</span>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
.hero { padding-top: 5rem; padding-bottom: 4rem; }
.hero-eyebrow { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
.hero-title { font-size: clamp(2rem, 5vw, 3.2rem); margin-bottom: 1.25rem; }
.accent { color: var(--orange); }
.hero-desc { max-width: 620px; font-size: 1.05rem; margin-bottom: 2rem; }
.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

.stats-row {
  display: flex;
  align-items: center;
  gap: 0;
  overflow-x: auto;
}
.stat { padding: 1.5rem 2.5rem; text-align: center; }
.stat-num { display: block; font-size: 1.6rem; font-weight: 600; color: var(--orange-light); font-family: var(--font-mono); }
.stat-label { display: block; font-size: 0.78rem; color: var(--muted); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.05em; }
.stat-div { width: 1px; height: 40px; background: var(--border); flex-shrink: 0; }

.section-heading { margin-bottom: 0.5rem; }
.section-sub { margin-bottom: 2.5rem; font-size: 1rem; }

.categories-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 1rem;
}

.cat-card { text-decoration: none; display: block; position: relative; }
.cat-count {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--orange-light);
  background: var(--orange-tint);
  border: 1px solid var(--orange-dark);
  border-radius: 100px;
  padding: 2px 8px;
  display: inline-block;
  margin-bottom: 0.6rem;
}
.cat-card h3 { color: var(--text); margin-bottom: 0.4rem; font-size: 1rem; }
.cat-card p  { font-size: 0.82rem; color: var(--muted); line-height: 1.5; }
.card-arrow { position: absolute; bottom: 1.5rem; right: 1.5rem; color: var(--orange); font-size: 1.1rem; opacity: 0; transition: opacity 0.2s; }
.cat-card:hover .card-arrow { opacity: 1; }

.engine-strip { display: flex; gap: 4rem; align-items: flex-start; }
.engine-text { flex: 1; }
.engine-text h2 { margin-bottom: 0; }
.tech-stack { display: flex; flex-wrap: wrap; gap: 0.5rem; align-content: flex-start; max-width: 280px; padding-top: 0.5rem; }

@media (max-width: 768px) {
  .engine-strip { flex-direction: column; }
  .tech-stack { max-width: 100%; }
  .stats-row { flex-wrap: wrap; justify-content: center; }
  .stat-div { display: none; }
}
</style>
