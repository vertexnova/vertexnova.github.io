---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SAMPLE_GROUPS, DEFAULT_SAMPLE_SLUG } from '../data/samples';

const catalogJSON = JSON.stringify(
  SAMPLE_GROUPS.flatMap(g =>
    g.samples.map(s => ({ ...s, group: g.id, groupLabel: g.label }))
  )
);
---

<BaseLayout>
  <script is:inline src="/coi-serviceworker.js"></script>

  <div class="shell">

    <!-- ── Left panel ─────────────────────────────────────────────── -->
    <nav class="panel" id="panel">

      <div class="panel-head">
        <div class="site-title">
          <img src="/favicon.svg" alt="" width="18" height="18" />
          <span>VertexNova</span>
          <span class="site-subtitle">/ WebGPU Samples</span>
        </div>
        <div class="panel-meta">
          <a href="/support">Browser support</a>
          <span class="dot">·</span>
          <a href="https://github.com/vertexnova/vnerhi" target="_blank" rel="noopener">GitHub ↗</a>
        </div>
      </div>

      <div class="search-wrap">
        <svg class="search-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          id="searchInput"
          type="search"
          placeholder="Filter samples…"
          autocomplete="off"
          spellcheck="false"
        />
      </div>

      <div class="sample-list" id="sampleList">
        {SAMPLE_GROUPS.map(group => (
          <div class="group" data-group={group.id}>
            <div class="group-label">{group.label}</div>
            <ul>
              {group.samples.map(s => (
                <li>
                  <a href={`#${s.slug}`} class="sample-link" data-slug={s.slug} data-target={s.target}>
                    {s.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
        <p class="no-results" id="noResults" hidden>No matches.</p>
      </div>

      <button class="panel-close" id="panelClose" aria-label="Close">✕</button>
    </nav>

    <!-- ── Main ───────────────────────────────────────────────────── -->
    <div class="main" id="main">

      <!-- Mobile top bar -->
      <div class="topbar">
        <button class="menu-btn" id="menuBtn" aria-label="Open sample list">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
            <rect y="2" width="16" height="1.5" rx="0.75"/>
            <rect y="7.25" width="16" height="1.5" rx="0.75"/>
            <rect y="12.5" width="16" height="1.5" rx="0.75"/>
          </svg>
        </button>
        <span id="topbarName" class="topbar-name"></span>
      </div>

      <!-- Welcome splash -->
      <div class="welcome" id="welcome">
        <div class="welcome-inner">
          <div class="welcome-mark">◈</div>
          <h2>WebGPU Samples</h2>
          <p>Select a sample from the list to run it live in the browser.</p>
          <p class="welcome-hint">
            Each demo is compiled from C++20 to WebAssembly with Emscripten.
          </p>
          <a href="/support" class="support-cta">Check browser support →</a>
        </div>
      </div>

      <!-- Sample frame -->
      <div class="sample-view" id="sampleView" hidden>
        <div class="info-bar" id="infoBar">
          <div class="info-main">
            <span class="info-title" id="infoTitle"></span>
            <span class="info-links">
              <a id="srcLink" href="#" target="_blank" rel="noopener">source ↗</a>
              <span class="sep">·</span>
              <a id="standaloneLink" href="#" target="_blank" rel="noopener">standalone ↗</a>
              <span class="sep">·</span>
              <a id="reportLink" href="#" target="_blank" rel="noopener">report issue ↗</a>
            </span>
          </div>
          <p class="info-desc" id="infoDesc"></p>
        </div>

        <div class="frame-area">
          <iframe
            id="sampleFrame"
            src="about:blank"
            title="WebGPU Sample"
            allow="cross-origin-isolated; gpu"
          ></iframe>

          <div class="overlay" id="overlayLoading">
            <div class="spinner"></div>
            <span>Loading…</span>
          </div>

          <div class="overlay unavail" id="overlayUnavail" hidden>
            <span class="warn">⚠</span>
            <p>Sample not yet deployed.</p>
            <p class="hint">Run locally: <code>./scripts/build_wasm.sh --serve</code></p>
          </div>
        </div>
      </div>
    </div>

    <div class="backdrop" id="backdrop"></div>
  </div>
</BaseLayout>

<style>
/* ── Shell ──────────────────────────────────────────────────────── */
.shell {
  display: flex;
  height: 100vh;
  overflow: hidden;
}

/* ── Panel ──────────────────────────────────────────────────────── */
.panel {
  width: 272px;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  background: var(--panel);
  border-right: 1px solid var(--border);
  overflow: hidden;
  font-family: var(--font-mono);
}

.panel-head {
  padding: 0.9rem 1rem 0.7rem;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.site-title {
  display: flex;
  align-items: center;
  gap: 7px;
  font-family: var(--font-sans);
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 5px;
}
.site-title img { opacity: 0.9; flex-shrink: 0; }
.site-subtitle {
  font-family: var(--font-sans);
  font-weight: 400;
  color: var(--muted);
  font-size: 0.82rem;
}

.panel-meta {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.72rem;
  color: var(--muted);
}
.panel-meta a { color: var(--muted); }
.panel-meta a:hover { color: var(--orange-light); }
.dot { color: var(--border); }

/* Search */
.search-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0.5rem 1rem;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.search-icon { color: var(--muted); flex-shrink: 0; }
#searchInput {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  font-family: var(--font-sans);
  font-size: 0.83rem;
  color: var(--text);
  min-width: 0;
}
#searchInput::placeholder { color: var(--muted); }

/* Sample list */
.sample-list {
  flex: 1;
  overflow-y: auto;
  padding: 0.4rem 0 1rem;
  overscroll-behavior: contain;
}
.sample-list::-webkit-scrollbar { width: 3px; }
.sample-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

.group { margin-bottom: 0.25rem; }
.group[hidden] { display: none; }

/* Separator line between groups */
.group + .group .group-label {
  border-top: 1px solid var(--border);
}

.group-label {
  font-family: var(--font-sans);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.02em;
  color: var(--orange-light);
  padding: 0.85rem 1rem 0.3rem;
}

.group ul { list-style: none; padding: 0; margin: 0; }

.sample-link {
  display: block;
  padding: 0.32rem 1rem;
  font-family: var(--font-sans);
  font-size: 0.875rem;
  color: #AEAEB2;
  text-decoration: none;
  border-left: 2px solid transparent;
  transition: color 0.1s, background 0.1s, border-color 0.1s;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.sample-link:hover {
  color: var(--text);
  background: var(--panel-hover);
}
.sample-link.active {
  color: var(--orange-light);
  border-left-color: var(--orange);
  background: var(--orange-tint);
  font-weight: 500;
}

.no-results {
  font-size: 0.75rem;
  color: var(--muted);
  padding: 0.6rem 1rem;
  margin: 0;
}

.panel-close { display: none; }

/* ── Main ───────────────────────────────────────────────────────── */
.main {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  min-width: 0;
}

/* Mobile topbar */
.topbar {
  display: none;
  align-items: center;
  gap: 0.75rem;
  height: 44px;
  padding: 0 1rem;
  border-bottom: 1px solid var(--border);
  background: var(--panel);
  flex-shrink: 0;
}
.menu-btn {
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 5px;
  color: var(--muted);
  padding: 5px 8px;
  cursor: pointer;
  display: flex;
  align-items: center;
}
.menu-btn:hover { border-color: var(--orange); color: var(--orange-light); }
.topbar-name {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  color: var(--muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Welcome */
.welcome {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 2rem;
}
.welcome-inner { max-width: 380px; }
.welcome-mark {
  font-size: 2.4rem;
  color: var(--orange);
  margin-bottom: 1.1rem;
  opacity: 0.85;
}
.welcome-inner h2 {
  font-family: var(--font-sans);
  font-size: 1.35rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 0.75rem;
  letter-spacing: -0.02em;
}
.welcome-inner p {
  font-family: var(--font-sans);
  font-size: 0.9rem;
  color: var(--muted);
  line-height: 1.7;
  margin-bottom: 0.4rem;
}
.welcome-hint {
  font-family: var(--font-mono);
  font-size: 0.78rem !important;
  color: #6E6E73;
}
.support-cta {
  display: inline-block;
  margin-top: 1.1rem;
  font-family: var(--font-sans);
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--orange-light);
}
.support-cta:hover { color: var(--orange); }

/* Sample view */
.sample-view {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  min-height: 0;
}

/* Info bar */
.info-bar {
  flex-shrink: 0;
  padding: 0.7rem 1.25rem 0.6rem;
  border-bottom: 1px solid var(--border);
  background: var(--panel);
}
.info-main {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  flex-wrap: wrap;
}
.info-title {
  font-family: var(--font-sans);
  font-size: 1rem;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.01em;
}
.info-links {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  font-family: var(--font-mono);
  font-size: 0.72rem;
}
.info-links a { color: var(--muted); }
.info-links a:hover { color: var(--orange-light); }
.sep { color: var(--border); }
.info-desc {
  font-family: var(--font-sans);
  font-size: 0.83rem;
  color: var(--muted);
  line-height: 1.6;
  margin-top: 0.3rem;
}

/* Frame */
.frame-area {
  flex: 1;
  position: relative;
  min-height: 0;
  background: #000;
}

#sampleFrame {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: none;
  display: block;
}

/* Overlays */
.overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  background: #0d0d0d;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--muted);
  text-align: center;
  padding: 2rem;
}
.overlay[hidden] { display: none; }
.spinner {
  width: 22px;
  height: 22px;
  border: 2px solid var(--border);
  border-top-color: var(--orange);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.warn { font-size: 1.4rem; color: var(--orange-dark); }
.overlay p { margin: 0; line-height: 1.6; }
.overlay .hint { font-size: 0.68rem !important; margin-top: 0.15rem !important; }

/* Mobile backdrop */
.backdrop {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 39;
  background: rgba(0,0,0,0.65);
}
.backdrop.visible { display: block; }

/* ── Responsive ─────────────────────────────────────────────────── */
@media (max-width: 700px) {
  .panel {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 40;
    width: min(280px, 88vw);
    transform: translateX(-100%);
    transition: transform 0.2s ease;
    box-shadow: 6px 0 32px rgba(0,0,0,0.5);
  }
  .panel.open { transform: translateX(0); }

  .panel-close {
    display: block;
    position: absolute;
    top: 0.7rem;
    right: 0.7rem;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--muted);
    font-size: 0.7rem;
    padding: 2px 6px;
    cursor: pointer;
    font-family: var(--font-mono);
    z-index: 1;
  }

  .topbar { display: flex; }
}
</style>

<script is:inline define:vars={{ catalogJSON, DEFAULT_SAMPLE_SLUG }}>
const catalog = JSON.parse(catalogJSON);

const panel          = document.getElementById('panel');
const backdrop       = document.getElementById('backdrop');
const panelClose     = document.getElementById('panelClose');
const menuBtn        = document.getElementById('menuBtn');
const welcome        = document.getElementById('welcome');
const sampleView     = document.getElementById('sampleView');
const sampleFrame    = document.getElementById('sampleFrame');
const overlayLoading = document.getElementById('overlayLoading');
const overlayUnavail = document.getElementById('overlayUnavail');
const infoTitle      = document.getElementById('infoTitle');
const infoDesc       = document.getElementById('infoDesc');
const srcLink        = document.getElementById('srcLink');
const standaloneLink = document.getElementById('standaloneLink');
const reportLink     = document.getElementById('reportLink');
const topbarName     = document.getElementById('topbarName');
const searchInput    = document.getElementById('searchInput');
const noResults      = document.getElementById('noResults');

// ── Mobile panel ───────────────────────────────────────────────────
function openPanel()  { panel.classList.add('open');    backdrop.classList.add('visible');    document.body.style.overflow = 'hidden'; }
function closePanel() { panel.classList.remove('open'); backdrop.classList.remove('visible'); document.body.style.overflow = ''; }
menuBtn?.addEventListener('click', openPanel);
panelClose?.addEventListener('click', closePanel);
backdrop?.addEventListener('click', closePanel);

// ── Search ─────────────────────────────────────────────────────────
searchInput?.addEventListener('input', () => {
  const q = searchInput.value.trim().toLowerCase();
  let any = false;
  document.querySelectorAll('.group').forEach(g => {
    let groupVisible = false;
    g.querySelectorAll('.sample-link').forEach(a => {
      const match = !q || a.textContent.toLowerCase().includes(q);
      a.parentElement.hidden = !match;
      if (match) groupVisible = true;
    });
    g.hidden = !groupVisible;
    if (groupVisible) any = true;
  });
  noResults.hidden = any;
});

// ── Load sample ────────────────────────────────────────────────────
let currentSlug = null;
const loadingLabel = document.querySelector('#overlayLoading span');

function loadSample(slug, force = false) {
  const s = catalog.find(x => x.slug === slug);
  if (!s) return;
  if (!force && currentSlug === slug) return;
  currentSlug = slug;

  if (window.location.hash !== '#' + slug) {
    history.pushState(null, '', '#' + slug);
  }

  document.querySelectorAll('.sample-link').forEach(el => {
    el.classList.toggle('active', el.dataset.slug === slug);
  });

  infoTitle.textContent  = s.title;
  infoDesc.textContent   = s.description;
  topbarName.textContent = s.title;

  const wasmUrl = '/wasm/' + s.target + '.html';
  standaloneLink.href = wasmUrl;
  srcLink.href = 'https://github.com/vertexnova/vnerhi/tree/main/samples/' + s.target;

  const issueUrl = new URL('https://github.com/vertexnova/vertexnova.github.io/issues/new');
  issueUrl.searchParams.set('template', 'webgpu-sample-bug.yml');
  issueUrl.searchParams.set('title', '[WebGPU] ' + s.title);
  reportLink.href = issueUrl.toString();

  welcome.hidden          = true;
  welcome.style.display   = '';
  sampleView.hidden       = false;
  overlayLoading.hidden   = false;
  overlayUnavail.hidden   = true;
  sampleFrame.src         = 'about:blank';

  // Same-origin iframes inherit isolation from the top-level page. Never
  // navigate the frame until this page is crossOriginIsolated.
  if (!window.crossOriginIsolated) {
    if (loadingLabel) loadingLabel.textContent = 'Enabling cross-origin isolation…';
    return;
  }

  if (loadingLabel) loadingLabel.textContent = 'Loading…';
  requestAnimationFrame(() => { sampleFrame.src = wasmUrl; });
  closePanel();
}

sampleFrame?.addEventListener('load', () => {
  if (sampleFrame.src === 'about:blank' || sampleFrame.src === location.href) return;
  overlayLoading.hidden = true;

  // Detect the Emscripten "not found" empty page
  try {
    const d = sampleFrame.contentDocument;
    if (d && d.body && d.body.children.length === 0) {
      overlayUnavail.hidden = false;
    }
  } catch (_) { /* cross-origin — assume loaded */ }
});

sampleFrame?.addEventListener('error', () => {
  overlayLoading.hidden = true;
  overlayUnavail.hidden = false;
});

// ── Nav link clicks ────────────────────────────────────────────────
document.querySelectorAll('.sample-link').forEach(el => {
  el.addEventListener('click', e => {
    e.preventDefault();
    loadSample(el.dataset.slug);
  });
});

// ── Hash routing ───────────────────────────────────────────────────
function handleHash() {
  const slug = location.hash.slice(1) || DEFAULT_SAMPLE_SLUG;
  const s = catalog.find(x => x.slug === slug);
  if (s) loadSample(slug);
}
window.addEventListener('popstate', handleHash);
handleHash();

// coi-serviceworker.js usually full-reloads once. If isolation arrives
// without reload, force-load the pending sample into the iframe.
if (!window.crossOriginIsolated) {
  const timer = setInterval(() => {
    if (!window.crossOriginIsolated) return;
    clearInterval(timer);
    if (currentSlug) loadSample(currentSlug, true);
  }, 100);
}
</script>
