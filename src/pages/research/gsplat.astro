.resources { margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--border); }
.resource-list { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1rem; }
.resource-link { display: flex; flex-direction: column; padding: 0.75rem 1rem; background: var(--panel); border: 1px solid var(--border); border-radius: 8px; text-decoration: none; transition: border-color 0.15s; }
.resource-link:hover { border-color: var(--orange-dark); }
.resource-title { font-size: 0.9rem; font-weight: 500; color: var(--orange-light); }
.resource-sub { font-size: 0.82rem; color: var(--muted); margin-top: 2px; }

@media (max-width: 768px) {
  .concept-grid { grid-template-columns: 1fr; }
  .return-grid { grid-template-columns: 1fr; }
}
</style>

<script>
document.querySelectorAll('.tab').forEach(tab => {
  tab.addEventListener('click', () => {
    const target = tab.dataset.tab;
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    tab.classList.add('active');
    document.getElementById(target)?.classList.add('active');
  });
});
</script>
