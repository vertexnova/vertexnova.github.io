---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface BrowserRow {
  browser: string;
  desktop: 'yes' | 'flag' | 'no' | 'partial';
  android: 'yes' | 'flag' | 'no' | 'partial' | '—';
  ios: 'yes' | 'flag' | 'no' | 'partial' | '—';
  notes: string;
}

const browsers: BrowserRow[] = [
  {
    browser: 'Chrome / Chromium',
    desktop: 'yes',
    android: 'yes',
    ios: 'no',
    notes: 'WebGPU enabled by default since Chrome 113 (May 2023).',
  },
  {
    browser: 'Microsoft Edge',
    desktop: 'yes',
    android: 'yes',
    ios: 'no',
    notes: 'WebGPU enabled by default since Edge 113.',
  },
  {
    browser: 'Safari',
    desktop: 'yes',
    android: '—',
    ios: 'yes',
    notes: 'WebGPU enabled by default since Safari 18 (macOS Sequoia / iOS 18, Sep 2024).',
  },
  {
    browser: 'Firefox',
    desktop: 'flag',
    android: 'no',
    ios: 'no',
    notes: 'Behind dom.webgpu.enabled flag. Not recommended for production use yet.',
  },
  {
    browser: 'Samsung Internet',
    desktop: '—',
    android: 'partial',
    ios: '—',
    notes: 'WebGPU support in progress; availability depends on the Chromium base version.',
  },
];

const statusLabel: Record<string, string> = {
  yes: '✓ Supported',
  flag: '⚑ Behind flag',
  no: '✗ Not supported',
  partial: '◑ Partial',
  '—': '—',
};

const statusClass: Record<string, string> = {
  yes: 'status-yes',
  flag: 'status-flag',
  no: 'status-no',
  partial: 'status-partial',
  '—': 'status-na',
};
---

<BaseLayout
  title="WebGPU Browser Support"
  description="Which browsers support WebGPU, and how to enable it. Platform compatibility table and setup instructions."
>
  <section class="section">
    <div class="container support-container">

      <!-- Header -->
      <nav class="breadcrumb">
        <a href="/samples" class="back-link">← WebGPU Samples</a>
      </nav>

      <div class="page-header">
        <span class="tag orange">WebGPU</span>
        <h1>Browser Support</h1>
        <p class="header-desc">
          These samples use WebGPU with Emscripten pthreads (SharedArrayBuffer).
          Both a WebGPU-capable browser <em>and</em> cross-origin isolation are required.
          Check the table below and follow the platform-specific steps if needed.
        </p>
      </div>

      <!-- Compatibility table -->
      <div class="table-wrap">
        <table class="compat-table">
          <thead>
            <tr>
              <th>Browser</th>
              <th>Desktop</th>
              <th>Android</th>
              <th>iOS / iPadOS</th>
              <th>Notes</th>
            </tr>
          </thead>
          <tbody>
            {browsers.map(row => (
              <tr>
                <td class="browser-name">{row.browser}</td>
                <td><span class={`status-badge ${statusClass[row.desktop]}`}>{statusLabel[row.desktop]}</span></td>
                <td><span class={`status-badge ${statusClass[row.android]}`}>{statusLabel[row.android]}</span></td>
                <td><span class={`status-badge ${statusClass[row.ios]}`}>{statusLabel[row.ios]}</span></td>
                <td class="notes-cell">{row.notes}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- SharedArrayBuffer note -->
      <div class="info-box">
        <div class="info-box-icon">ⓘ</div>
        <div>
          <strong>SharedArrayBuffer requirement</strong>
          <p>
            The samples use Emscripten pthreads, which requires
            <code>SharedArrayBuffer</code>. This API is only available when the
            page is <em>cross-origin isolated</em> (the server sends
            <code>Cross-Origin-Opener-Policy: same-origin</code> and
            <code>Cross-Origin-Embedder-Policy: require-corp</code>). This site
            handles that automatically via a service worker — no action needed
            on supported browsers.
          </p>
        </div>
      </div>

      <div class="divider" style="margin: 3rem 0;"></div>

      <!-- Per-platform setup ------------------------------------------------ -->
      <h2 class="section-heading">Setup instructions</h2>

      <!-- Chrome / Edge -->
      <div class="platform-block">
        <div class="platform-header">
          <span class="platform-badge supported">Chrome & Edge — Desktop</span>
          <span class="platform-status">Works out of the box</span>
        </div>
        <p class="platform-desc">
          WebGPU is enabled by default in Chrome 113+ and Edge 113+. No configuration needed.
          Make sure your GPU drivers are up to date for best performance.
        </p>
        <div class="steps">
          <div class="step">
            <span class="step-num">1</span>
            <span>Update Chrome or Edge to version 113 or later.</span>
          </div>
          <div class="step">
            <span class="step-num">2</span>
            <span>Open any sample — it should launch immediately.</span>
          </div>
          <div class="step">
            <span class="step-num">3</span>
            <span>
              If a sample fails, open <code>chrome://gpu</code> and verify
              that <strong>WebGPU</strong> shows <em>Enabled</em>.
            </span>
          </div>
        </div>
      </div>

      <!-- Safari -->
      <div class="platform-block">
        <div class="platform-header">
          <span class="platform-badge supported">Safari — macOS & iOS 18+</span>
          <span class="platform-status">Works out of the box</span>
        </div>
        <p class="platform-desc">
          WebGPU shipped in Safari 18 (macOS Sequoia 15, iOS 18, September 2024).
          Older Safari versions require Tech Preview or a feature flag.
        </p>
        <div class="steps">
          <div class="step">
            <span class="step-num">1</span>
            <span>
              On <strong>macOS</strong>: update to macOS Sequoia 15 + Safari 18,
              or install
              <a href="https://developer.apple.com/safari/technology-preview/" target="_blank" rel="noopener">Safari Technology Preview</a>.
            </span>
          </div>
          <div class="step">
            <span class="step-num">2</span>
            <span>
              On <strong>iOS / iPadOS</strong>: update to iOS 18.
            </span>
          </div>
          <div class="step">
            <span class="step-num">3</span>
            <span>
              If on Safari 17, enable the flag manually:
              <strong>Safari → Settings → Feature Flags → WebGPU</strong>.
            </span>
          </div>
        </div>
      </div>

      <!-- Chrome Android -->
      <div class="platform-block">
        <div class="platform-header">
          <span class="platform-badge supported">Chrome — Android</span>
          <span class="platform-status">Works out of the box</span>
        </div>
        <p class="platform-desc">
          WebGPU is available on Chrome for Android (version 121+) on devices
          with a Vulkan-capable GPU (most Android 8+ devices).
        </p>
        <div class="steps">
          <div class="step">
            <span class="step-num">1</span>
            <span>Update Chrome to version 121 or later.</span>
          </div>
          <div class="step">
            <span class="step-num">2</span>
            <span>
              If WebGPU is not available, your device GPU may not support Vulkan.
              Check <code>chrome://gpu</code> in the address bar.
            </span>
          </div>
        </div>
      </div>

      <!-- Firefox -->
      <div class="platform-block">
        <div class="platform-header">
          <span class="platform-badge flag">Firefox — Desktop</span>
          <span class="platform-status">Behind a flag</span>
        </div>
        <p class="platform-desc">
          WebGPU is implemented but gated behind an about:config flag in Firefox.
          Enable it manually — expect rough edges, as the implementation is not
          yet production-ready.
        </p>
        <div class="steps">
          <div class="step">
            <span class="step-num">1</span>
            <span>Open Firefox and type <code>about:config</code> in the address bar. Accept the warning.</span>
          </div>
          <div class="step">
            <span class="step-num">2</span>
            <span>Search for <code>dom.webgpu.enabled</code> and set it to <strong>true</strong>.</span>
          </div>
          <div class="step">
            <span class="step-num">3</span>
            <span>
              On Windows, also enable <code>gfx.webrender.all</code> → <strong>true</strong>
              if samples fail to initialise.
            </span>
          </div>
          <div class="step">
            <span class="step-num">4</span>
            <span>Restart Firefox and try the sample.</span>
          </div>
        </div>
        <div class="platform-warning">
          ⚠ Firefox WebGPU may be incomplete or unstable. Some samples may not work correctly.
        </div>
      </div>

      <div class="divider" style="margin: 3rem 0;"></div>

      <!-- Reporting issues -->
      <h2 class="section-heading">Found a problem?</h2>
      <p style="margin-bottom:1.5rem; font-size:0.95rem;">
        If a sample crashes, renders incorrectly, or fails to launch on a supported browser,
        please file a bug. Include your browser version, OS, and GPU so we can reproduce it.
      </p>
      <a
        href="https://github.com/vertexnova/vertexnova.github.io/issues/new?template=webgpu-sample-bug.yml"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary"
      >
        Report a WebGPU sample bug ↗
      </a>

    </div>
  </section>
</BaseLayout>

<style>
.support-container { max-width: 900px; }

.breadcrumb { margin-bottom: 2rem; }
.back-link { font-size: 0.88rem; color: var(--muted); text-decoration: none; }
.back-link:hover { color: var(--orange-light); }

.page-header { margin-bottom: 2.5rem; }
.page-header h1 { margin-top: 1rem; margin-bottom: 0.75rem; }
.header-desc { color: var(--muted); font-size: 1rem; max-width: 680px; line-height: 1.75; }
.header-desc em { color: var(--text); font-style: normal; font-weight: 500; }

/* Table */
.table-wrap {
  overflow-x: auto;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  margin-bottom: 1.5rem;
}

.compat-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.875rem;
}

.compat-table th {
  background: var(--panel);
  color: var(--muted);
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  font-family: var(--font-mono);
  font-weight: 600;
  padding: 0.75rem 1rem;
  text-align: left;
  border-bottom: 1px solid var(--border);
  white-space: nowrap;
}

.compat-table td {
  padding: 0.875rem 1rem;
  border-bottom: 1px solid var(--border);
  vertical-align: middle;
}

.compat-table tr:last-child td { border-bottom: none; }
.compat-table tr:hover td { background: color-mix(in srgb, var(--panel) 40%, transparent); }

.browser-name { font-weight: 500; color: var(--text); white-space: nowrap; }
.notes-cell { color: var(--muted); line-height: 1.55; font-size: 0.82rem; }

.status-badge {
  display: inline-block;
  font-size: 0.72rem;
  font-family: var(--font-mono);
  padding: 2px 8px;
  border-radius: 100px;
  border: 1px solid;
  white-space: nowrap;
}

.status-yes     { color: #7abf82; border-color: #1a4a20; background: #0d2410; }
.status-flag    { color: #f0b429; border-color: #7a5f00; background: #2a2000; }
.status-no      { color: var(--muted); border-color: var(--border); background: transparent; }
.status-partial { color: var(--orange-light); border-color: var(--orange-dark); background: var(--orange-tint); }
.status-na      { color: var(--muted); border-color: transparent; background: transparent; }

/* Info box */
.info-box {
  display: flex;
  gap: 1rem;
  background: var(--panel);
  border: 1px solid var(--border);
  border-left: 3px solid var(--orange-dark);
  border-radius: var(--radius);
  padding: 1.1rem 1.25rem;
  font-size: 0.875rem;
}

.info-box-icon { font-size: 1.1rem; color: var(--orange-light); flex-shrink: 0; padding-top: 1px; }
.info-box strong { color: var(--text); display: block; margin-bottom: 0.35rem; }
.info-box p { margin: 0; color: var(--muted); line-height: 1.65; }

/* Section heading */
.section-heading { font-size: 1.4rem; margin-bottom: 1.5rem; }

/* Platform blocks */
.platform-block {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
  margin-bottom: 1rem;
}

.platform-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.75rem;
  flex-wrap: wrap;
}

.platform-badge {
  font-size: 0.78rem;
  font-weight: 600;
  padding: 3px 10px;
  border-radius: 100px;
  border: 1px solid;
}

.platform-badge.supported {
  color: #7abf82;
  border-color: #1a4a20;
  background: #0d2410;
}

.platform-badge.flag {
  color: #f0b429;
  border-color: #7a5f00;
  background: #2a2000;
}

.platform-status {
  font-size: 0.78rem;
  color: var(--muted);
  font-family: var(--font-mono);
}

.platform-desc {
  color: var(--muted);
  font-size: 0.875rem;
  line-height: 1.65;
  margin-bottom: 1rem;
}

.steps {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.step {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  font-size: 0.875rem;
  color: var(--muted);
  line-height: 1.6;
}

.step-num {
  flex-shrink: 0;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--panel-mid);
  border: 1px solid var(--border);
  color: var(--orange-light);
  font-size: 0.7rem;
  font-family: var(--font-mono);
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.step a { color: var(--orange-light); }
.step a:hover { color: var(--orange); }

.platform-warning {
  margin-top: 1rem;
  padding: 0.6rem 0.9rem;
  background: color-mix(in srgb, #7a3315 20%, transparent);
  border: 1px solid var(--orange-dark);
  border-radius: var(--radius);
  font-size: 0.8rem;
  color: var(--orange-light);
}
</style>
