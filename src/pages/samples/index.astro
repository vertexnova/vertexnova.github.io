---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SAMPLE_GROUPS, DEFAULT_SAMPLE_SLUG } from '../../data/samples';

// Serialise catalog for client-side JS.
const catalogJSON = JSON.stringify(
  SAMPLE_GROUPS.flatMap(g =>
    g.samples.map(s => ({ ...s, group: g.id, groupLabel: g.label }))
  )
);
---

<BaseLayout
  title="WebGPU Samples"
  description="Interactive WebGPU samples built with VertexNova — running live in the browser via WebAssembly."
>
  <!-- Cross-origin isolation required for SharedArrayBuffer / pthreads -->
  <script is:inline src="/coi-serviceworker.js"></script>

  <div class="explorer">

    <!-- ── Mobile top bar ─────────────────────────────────────────────── -->
    <div class="mobile-bar">
      <button class="menu-btn" id="menuBtn" aria-label="Toggle sample list">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <rect y="2"  width="18" height="2" rx="1" fill="currentColor"/>
          <rect y="8"  width="18" height="2" rx="1" fill="currentColor"/>
          <rect y="14" width="18" height="2" rx="1" fill="currentColor"/>
        </svg>
        <span id="menuLabel">Samples</span>
      </button>
      <span class="mobile-title" id="mobileSampleTitle">Select a sample</span>
    </div>

    <!-- ── Sidebar ────────────────────────────────────────────────────── -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <span class="sidebar-heading">WebGPU Samples</span>
        <a href="/samples/support" class="sidebar-support-link">Browser support ↗</a>
      </div>

      <nav class="sidebar-nav">
        {SAMPLE_GROUPS.map(group => (
          <div class="nav-group">
            <div class="nav-group-label">{group.label}</div>
            <ul class="nav-group-list">
              {group.samples.map(s => (
                <li>
                  <a
                    href={`#${s.slug}`}
                    class="nav-item"
                    data-slug={s.slug}
                    aria-label={s.title}
                  >
                    {s.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </aside>

    <!-- ── Overlay (mobile) ───────────────────────────────────────────── -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- ── Main panel ─────────────────────────────────────────────────── -->
    <div class="panel" id="panel">

      <!-- Welcome / no-selection state -->
      <div class="welcome" id="welcome">
        <div class="welcome-inner">
          <div class="welcome-icon">◈</div>
          <h2>WebGPU Samples</h2>
          <p>
            Select a sample from the list to launch it. Each demo runs live in the
            browser using WebAssembly compiled from C++20 with Emscripten.
          </p>
          <div class="welcome-pills">
            <span class="pill orange">WebGPU</span>
            <span class="pill">WebAssembly</span>
            <span class="pill">C++20</span>
            <span class="pill">Emscripten</span>
          </div>
          <a href="/samples/support" class="btn btn-ghost" style="margin-top:1.5rem">
            Check browser support →
          </a>
        </div>
      </div>

      <!-- Active sample view -->
      <div class="sample-view" id="sampleView" hidden>

        <!-- Info bar -->
        <div class="info-bar">
          <div class="info-left">
            <span class="info-group-badge" id="infoGroupBadge"></span>
            <h1 class="info-title" id="infoTitle"></h1>
            <p class="info-desc" id="infoDesc"></p>
          </div>
          <div class="info-actions">
            <a
              id="reportBtn"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-ghost btn-sm report-btn"
            >
              Report issue ↗
            </a>
            <a
              id="openFullBtn"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-ghost btn-sm"
            >
              Open full screen ↗
            </a>
          </div>
        </div>

        <!-- Canvas area with padding -->
        <div class="canvas-wrap">
          <div class="canvas-frame">
            <iframe
              id="sampleFrame"
              src=""
              title="WebGPU Sample"
              allow="cross-origin-isolated"
            ></iframe>

            <!-- Overlay shown while sample is loading -->
            <div class="frame-loading" id="frameLoading">
              <div class="loading-spinner"></div>
              <span>Loading sample…</span>
            </div>

            <!-- Overlay shown when sample isn't deployed yet -->
            <div class="frame-unavailable" id="frameUnavailable" hidden>
              <div class="unavailable-icon">⚠</div>
              <p>Sample not yet deployed to the web.</p>
              <p class="unavailable-hint">
                Run locally with
                <code>./scripts/build_wasm.sh --serve</code> in the
                <a href="https://github.com/vertexnova/vnerhi" target="_blank" rel="noopener">vnerhi</a>
                repository.
              </p>
            </div>
          </div>
        </div>

        <!-- Footer note -->
        <div class="canvas-note">
          <span>
            Requires a WebGPU-capable browser —
            <a href="/samples/support">check support ↗</a>
          </span>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>

<style>
/* ── Layout ──────────────────────────────────────────────────────────────── */
.explorer {
  display: flex;
  height: calc(100vh - 60px); /* 60px = site header */
  overflow: hidden;
  position: relative;
}

/* ── Mobile bar ──────────────────────────────────────────────────────────── */
.mobile-bar {
  display: none;
  position: fixed;
  top: 60px;
  left: 0;
  right: 0;
  z-index: 50;
  height: 48px;
  background: var(--panel);
  border-bottom: 1px solid var(--border);
  align-items: center;
  gap: 0.75rem;
  padding: 0 1rem;
}

.menu-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text);
  padding: 5px 10px;
  font-size: 0.8rem;
  cursor: pointer;
  font-family: var(--font-sans);
  white-space: nowrap;
  flex-shrink: 0;
}
.menu-btn:hover { border-color: var(--orange); color: var(--orange-light); }

.mobile-title {
  font-size: 0.82rem;
  color: var(--muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ── Sidebar ─────────────────────────────────────────────────────────────── */
.sidebar {
  width: 272px;
  flex-shrink: 0;
  background: var(--panel);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  overscroll-behavior: contain;
}

.sidebar-header {
  padding: 1rem 1.25rem 0.75rem;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 0.5rem;
  flex-shrink: 0;
}

.sidebar-heading {
  font-size: 0.72rem;
  font-family: var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--muted);
  font-weight: 500;
}

.sidebar-support-link {
  font-size: 0.72rem;
  color: var(--muted);
  white-space: nowrap;
}
.sidebar-support-link:hover { color: var(--orange-light); }

.sidebar-nav {
  padding: 0.75rem 0 2rem;
  flex: 1;
}

.nav-group { margin-bottom: 0.25rem; }

.nav-group-label {
  font-size: 0.68rem;
  font-family: var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--muted);
  padding: 0.75rem 1.25rem 0.3rem;
  font-weight: 600;
}

.nav-group-list { list-style: none; padding: 0; margin: 0; }

.nav-item {
  display: block;
  padding: 0.45rem 1.25rem;
  font-size: 0.875rem;
  color: var(--muted);
  border-left: 2px solid transparent;
  transition: color 0.12s, background 0.12s, border-color 0.12s;
  text-decoration: none;
  line-height: 1.4;
}
.nav-item:hover {
  color: var(--text);
  background: color-mix(in srgb, var(--panel-mid) 60%, transparent);
}
.nav-item.active {
  color: var(--orange-light);
  border-left-color: var(--orange);
  background: var(--orange-tint);
  font-weight: 500;
}

/* ── Sidebar overlay (mobile) ────────────────────────────────────────────── */
.sidebar-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 39;
  background: rgba(0,0,0,0.55);
}
.sidebar-overlay.visible { display: block; }

/* ── Panel ───────────────────────────────────────────────────────────────── */
.panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--bg);
  min-width: 0;
}

/* ── Welcome state ───────────────────────────────────────────────────────── */
.welcome {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}

.welcome-inner {
  max-width: 420px;
  text-align: center;
}

.welcome-icon {
  font-size: 2.5rem;
  color: var(--orange);
  margin-bottom: 1rem;
}

.welcome-inner h2 { margin-bottom: 0.75rem; }
.welcome-inner p  { font-size: 0.95rem; margin-bottom: 1.25rem; }

.welcome-pills {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.4rem;
}

.pill {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  padding: 3px 10px;
  border-radius: 100px;
  border: 1px solid var(--border);
  color: var(--muted);
  background: var(--panel);
}
.pill.orange {
  border-color: var(--orange-dark);
  color: var(--orange-light);
  background: var(--orange-tint);
}

/* ── Sample view ─────────────────────────────────────────────────────────── */
.sample-view {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  min-height: 0;
}

/* Info bar */
.info-bar {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1.5rem;
  padding: 1.25rem 1.75rem 1rem;
  border-bottom: 1px solid var(--border);
  background: var(--panel);
  flex-shrink: 0;
}

.info-left { flex: 1; min-width: 0; }

.info-group-badge {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 2px 8px;
  border-radius: 100px;
  border: 1px solid var(--orange-dark);
  color: var(--orange-light);
  background: var(--orange-tint);
  margin-bottom: 0.45rem;
}

.info-title {
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--text);
  margin: 0 0 0.35rem;
  letter-spacing: -0.01em;
}

.info-desc {
  font-size: 0.875rem;
  color: var(--muted);
  line-height: 1.6;
  margin: 0;
  max-width: 640px;
}

.info-actions {
  display: flex;
  gap: 0.5rem;
  flex-shrink: 0;
  align-items: flex-start;
  padding-top: 0.15rem;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.btn-sm { padding: 6px 14px; font-size: 0.8rem; }

.report-btn { color: var(--muted); }
.report-btn:hover { color: var(--orange-light); border-color: var(--orange); }

/* Canvas area */
.canvas-wrap {
  flex: 1;
  padding: 1.25rem 1.75rem;
  display: flex;
  flex-direction: column;
  min-height: 0;
  overflow: hidden;
}

.canvas-frame {
  flex: 1;
  position: relative;
  border-radius: var(--radius-lg);
  border: 1px solid var(--border);
  overflow: hidden;
  background: #000;
  min-height: 0;
}

/* The inner iframe fills the frame entirely */
#sampleFrame {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: none;
  display: block;
}

/* Loading overlay */
.frame-loading {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  background: #0d0d0d;
  color: var(--muted);
  font-size: 0.85rem;
  font-family: var(--font-mono);
  pointer-events: none;
}

.loading-spinner {
  width: 28px;
  height: 28px;
  border: 2px solid var(--border);
  border-top-color: var(--orange);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* Unavailable overlay */
.frame-unavailable {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.6rem;
  background: #0d0d0d;
  color: var(--muted);
  font-size: 0.875rem;
  text-align: center;
  padding: 2rem;
}

.unavailable-icon {
  font-size: 2rem;
  color: var(--orange-dark);
  margin-bottom: 0.25rem;
}

.frame-unavailable p { margin: 0; line-height: 1.6; }
.frame-unavailable a { color: var(--orange-light); }

.unavailable-hint {
  font-size: 0.8rem;
  color: var(--muted);
  max-width: 360px;
  margin-top: 0.25rem !important;
}

/* Bottom note */
.canvas-note {
  padding: 0.5rem 1.75rem 0.75rem;
  font-size: 0.75rem;
  color: var(--muted);
  flex-shrink: 0;
}
.canvas-note a { color: var(--orange-light); }

/* ── Responsive ──────────────────────────────────────────────────────────── */
@media (max-width: 768px) {
  .explorer {
    flex-direction: column;
    height: calc(100vh - 60px - 48px); /* account for mobile bar */
    margin-top: 48px;
  }

  .mobile-bar { display: flex; }

  .sidebar {
    position: fixed;
    top: 60px;
    left: 0;
    bottom: 0;
    z-index: 40;
    width: min(300px, 88vw);
    transform: translateX(-100%);
    transition: transform 0.25s ease;
    border-right-color: var(--border);
  }
  .sidebar.open { transform: translateX(0); }

  .info-bar {
    flex-direction: column;
    gap: 0.75rem;
    padding: 1rem;
  }
  .info-actions { justify-content: flex-start; }

  .canvas-wrap { padding: 0.75rem 1rem; }
  .canvas-note { padding: 0.4rem 1rem 0.6rem; }
}
</style>

<script define:vars={{ catalogJSON, DEFAULT_SAMPLE_SLUG }}>
const catalog = JSON.parse(catalogJSON);

// ── DOM refs ────────────────────────────────────────────────────────────────
const welcome         = document.getElementById('welcome');
const sampleView      = document.getElementById('sampleView');
const sampleFrame     = document.getElementById('sampleFrame');
const frameLoading    = document.getElementById('frameLoading');
const frameUnavail    = document.getElementById('frameUnavailable');
const infoTitle       = document.getElementById('infoTitle');
const infoDesc        = document.getElementById('infoDesc');
const infoGroupBadge  = document.getElementById('infoGroupBadge');
const reportBtn       = document.getElementById('reportBtn');
const openFullBtn     = document.getElementById('openFullBtn');
const mobileSampleTitle = document.getElementById('mobileSampleTitle');

// ── Sidebar toggle (mobile) ─────────────────────────────────────────────────
const menuBtn      = document.getElementById('menuBtn');
const sidebar      = document.getElementById('sidebar');
const overlay      = document.getElementById('sidebarOverlay');

function openSidebar() {
  sidebar.classList.add('open');
  overlay.classList.add('visible');
  document.body.style.overflow = 'hidden';
}
function closeSidebar() {
  sidebar.classList.remove('open');
  overlay.classList.remove('visible');
  document.body.style.overflow = '';
}

menuBtn?.addEventListener('click', () =>
  sidebar.classList.contains('open') ? closeSidebar() : openSidebar()
);
overlay?.addEventListener('click', closeSidebar);

// ── Sample selection ────────────────────────────────────────────────────────
function slugFromHash() {
  const h = window.location.hash.slice(1);
  return h || null;
}

function selectSample(slug) {
  const sample = catalog.find(s => s.slug === slug);
  if (!sample) return;

  // Update URL without reloading.
  if (window.location.hash !== `#${slug}`) {
    history.pushState(null, '', `#${slug}`);
  }

  // Update sidebar active state.
  document.querySelectorAll('.nav-item').forEach(el => {
    el.classList.toggle('active', el.dataset.slug === slug);
  });

  // Update info bar.
  infoTitle.textContent       = sample.title;
  infoDesc.textContent        = sample.description;
  infoGroupBadge.textContent  = sample.groupLabel;
  mobileSampleTitle.textContent = sample.title;

  // Build report URL with pre-filled sample name.
  const issueUrl = new URL(
    'https://github.com/vertexnova/vertexnova.github.io/issues/new'
  );
  issueUrl.searchParams.set('template', 'webgpu-sample-bug.yml');
  issueUrl.searchParams.set('title', `[WebGPU Sample] ${sample.title}`);
  reportBtn.href = issueUrl.toString();

  // WASM page path — served from /samples/wasm/{target}/{target}.html
  const wasmPath = `/samples/wasm/${sample.target}/${sample.target}.html`;
  openFullBtn.href = wasmPath;

  // Show sample view, hide welcome.
  welcome.style.display   = 'none';
  sampleView.hidden       = false;

  // Show loading state while iframe loads.
  frameLoading.style.display  = 'flex';
  frameUnavail.hidden         = true;
  sampleFrame.src             = '';

  // Small delay so the loading indicator is visible before the heavy iframe.
  requestAnimationFrame(() => {
    sampleFrame.src = wasmPath;
  });

  // Close mobile sidebar after selection.
  closeSidebar();
}

// Hide loading overlay once iframe content has loaded.
sampleFrame?.addEventListener('load', () => {
  frameLoading.style.display = 'none';
  // Heuristic: if the iframe lands on a 404-ish empty page, show unavailable.
  try {
    const iframeDoc = sampleFrame.contentDocument;
    if (iframeDoc && iframeDoc.title === '' && iframeDoc.body?.children.length === 0) {
      frameUnavail.hidden = false;
    }
  } catch (_) {
    // Cross-origin frames throw; if we can't inspect, trust the load event.
  }
});

sampleFrame?.addEventListener('error', () => {
  frameLoading.style.display = 'none';
  frameUnavail.hidden = false;
});

// ── Nav link clicks ─────────────────────────────────────────────────────────
document.querySelectorAll('.nav-item').forEach(el => {
  el.addEventListener('click', (e) => {
    e.preventDefault();
    selectSample(el.dataset.slug);
  });
});

// ── Initial load & back/forward ─────────────────────────────────────────────
function handleHash() {
  const slug = slugFromHash() || DEFAULT_SAMPLE_SLUG;
  selectSample(slug);
}

window.addEventListener('popstate', handleHash);
handleHash();
</script>
