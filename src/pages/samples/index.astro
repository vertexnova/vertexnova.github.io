---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SAMPLE_GROUPS, DEFAULT_SAMPLE_SLUG } from '../../data/samples';

const catalogJSON = JSON.stringify(
  SAMPLE_GROUPS.flatMap(g =>
    g.samples.map(s => ({ ...s, group: g.id, groupLabel: g.label }))
  )
);
const groupsJSON = JSON.stringify(
  SAMPLE_GROUPS.map(g => ({ id: g.id, label: g.label }))
);
---

<BaseLayout
  title="WebGPU Samples"
  description="Interactive WebGPU samples from the VertexNova rendering engine — live in the browser via WebAssembly."
>
  <!-- COOP/COEP for SharedArrayBuffer (Emscripten pthreads) -->
  <script is:inline src="/coi-serviceworker.js"></script>

  <div class="shell">

    <!-- ── Left panel ───────────────────────────────────────────────── -->
    <nav class="panel" id="panel">

      <div class="panel-head">
        <a href="/" class="panel-logo">
          <img src="/favicon.svg" alt="" width="16" height="16" />
          <span>VertexNova</span>
        </a>
        <span class="panel-sub">WebGPU Samples</span>
      </div>

      <div class="panel-search">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          type="search"
          id="searchInput"
          placeholder="Filter samples…"
          autocomplete="off"
          spellcheck="false"
        />
      </div>

      <div class="sample-list" id="sampleList">
        {SAMPLE_GROUPS.map(group => (
          <div class="group" data-group={group.id}>
            <div class="group-label">{group.label}</div>
            <ul>
              {group.samples.map(s => (
                <li>
                  <a href={`#${s.slug}`} class="sample-link" data-slug={s.slug}>
                    {s.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
        <p class="no-results" id="noResults" hidden>No samples match.</p>
      </div>

      <div class="panel-footer">
        <a href="/samples/support">Browser support</a>
        <span class="divider-dot">·</span>
        <a href="https://github.com/vertexnova/vnerhi" target="_blank" rel="noopener">GitHub</a>
      </div>

      <!-- Mobile toggle -->
      <button class="panel-close" id="panelClose" aria-label="Close panel">✕</button>
    </nav>

    <!-- ── Main area ─────────────────────────────────────────────────── -->
    <div class="main" id="main">

      <!-- Mobile header -->
      <div class="mobile-header">
        <button class="menu-btn" id="menuBtn" aria-label="Open sample list">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor">
            <rect y="2" width="18" height="2" rx="1"/>
            <rect y="8" width="18" height="2" rx="1"/>
            <rect y="14" width="18" height="2" rx="1"/>
          </svg>
        </button>
        <span class="mobile-sample-name" id="mobileName">Select a sample</span>
      </div>

      <!-- Welcome (no sample selected) -->
      <div class="welcome" id="welcome">
        <div class="welcome-inner">
          <div class="welcome-glyph">◈</div>
          <h2>WebGPU Samples</h2>
          <p>
            Select a sample from the list to run it live.<br />
            Each demo is compiled from C++20 to WebAssembly with Emscripten.
          </p>
          <a href="/samples/support" class="support-link">Check browser support →</a>
        </div>
      </div>

      <!-- Sample view -->
      <div class="sample-view" id="sampleView" hidden>

        <div class="sample-info" id="sampleInfo">
          <div class="info-left">
            <h1 id="infoTitle"></h1>
            <div class="info-links">
              <a id="srcLink" href="#" target="_blank" rel="noopener">View source ↗</a>
              <span class="sep">—</span>
              <a id="standaloneLink" href="#" target="_blank" rel="noopener">Open standalone ↗</a>
              <span class="sep">—</span>
              <a id="reportLink" href="#" target="_blank" rel="noopener">Report issue ↗</a>
            </div>
            <p id="infoDesc"></p>
          </div>
        </div>

        <div class="frame-wrap">
          <div class="frame-border" id="frameBorder">
            <iframe
              id="sampleFrame"
              src=""
              title="WebGPU Sample"
              allow="cross-origin-isolated"
            ></iframe>

            <div class="overlay loading" id="overlayLoading">
              <div class="spinner"></div>
              <span>Loading…</span>
            </div>

            <div class="overlay unavailable" id="overlayUnavail" hidden>
              <span class="warn-icon">⚠</span>
              <p>Sample not yet deployed.</p>
              <p class="hint">
                Run locally:&nbsp;
                <code>./scripts/build_wasm.sh --serve</code>
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Mobile overlay -->
    <div class="panel-overlay" id="panelOverlay"></div>
  </div>
</BaseLayout>

<style>
/* ── Reset the BaseLayout <main> padding for this full-height page ── */
:global(main) {
  padding: 0 !important;
}

/* ── Shell ──────────────────────────────────────────────────────────── */
.shell {
  display: flex;
  height: calc(100vh - 60px);   /* 60px = site nav */
  overflow: hidden;
  font-family: var(--font-mono);
}

/* ── Left panel ─────────────────────────────────────────────────────── */
.panel {
  width: 280px;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  background: var(--panel);
  border-right: 1px solid var(--border);
  overflow: hidden;
}

.panel-head {
  padding: 1rem 1rem 0.6rem;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.panel-logo {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--text);
  text-decoration: none;
  margin-bottom: 2px;
}
.panel-logo:hover { color: var(--orange-light); }
.panel-logo img { opacity: 0.85; }

.panel-sub {
  display: block;
  font-size: 0.7rem;
  color: var(--muted);
  letter-spacing: 0.04em;
}

/* Search */
.panel-search {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0.6rem 1rem;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.panel-search svg { color: var(--muted); flex-shrink: 0; }

#searchInput {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--text);
  min-width: 0;
}
#searchInput::placeholder { color: var(--muted); }

/* Sample list */
.sample-list {
  flex: 1;
  overflow-y: auto;
  padding: 0.5rem 0 1rem;
  overscroll-behavior: contain;
}

.group { margin-bottom: 0.25rem; }

.group-label {
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--muted);
  padding: 0.6rem 1rem 0.25rem;
  font-weight: 600;
}

.group ul { list-style: none; padding: 0; margin: 0; }

.sample-link {
  display: block;
  padding: 0.3rem 1rem;
  font-size: 0.82rem;
  color: var(--muted);
  text-decoration: none;
  border-left: 2px solid transparent;
  transition: color 0.1s, background 0.1s, border-color 0.1s;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.sample-link:hover {
  color: var(--text);
  background: var(--panel-mid);
}
.sample-link.active {
  color: var(--orange-light);
  border-left-color: var(--orange);
  background: var(--orange-tint);
}

.group[hidden] { display: none; }
.no-results {
  font-size: 0.78rem;
  color: var(--muted);
  padding: 0.75rem 1rem;
  margin: 0;
}

/* Panel footer */
.panel-footer {
  flex-shrink: 0;
  padding: 0.6rem 1rem;
  border-top: 1px solid var(--border);
  font-size: 0.72rem;
  display: flex;
  gap: 0.4rem;
  align-items: center;
}
.panel-footer a { color: var(--muted); }
.panel-footer a:hover { color: var(--orange-light); }
.divider-dot { color: var(--border); }

.panel-close { display: none; }

/* ── Main area ──────────────────────────────────────────────────────── */
.main {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  min-width: 0;
  background: var(--bg);
}

/* Mobile header */
.mobile-header {
  display: none;
  align-items: center;
  gap: 0.75rem;
  padding: 0 1rem;
  height: 44px;
  border-bottom: 1px solid var(--border);
  background: var(--panel);
  flex-shrink: 0;
}

.menu-btn {
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 5px;
  color: var(--muted);
  padding: 4px 8px;
  cursor: pointer;
  display: flex;
  align-items: center;
}
.menu-btn:hover { border-color: var(--orange); color: var(--orange-light); }

.mobile-sample-name {
  font-size: 0.8rem;
  color: var(--muted);
  font-family: var(--font-mono);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Welcome */
.welcome {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 2rem;
  font-family: var(--font-mono);
}

.welcome-inner { max-width: 380px; }
.welcome-glyph { font-size: 2.5rem; color: var(--orange); margin-bottom: 1rem; }
.welcome-inner h2 { font-family: var(--font-mono); font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; color: var(--text); }
.welcome-inner p  { font-size: 0.82rem; color: var(--muted); line-height: 1.7; margin-bottom: 1rem; }
.support-link { font-size: 0.78rem; color: var(--orange-light); }
.support-link:hover { color: var(--orange); }

/* Sample view */
.sample-view {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  min-height: 0;
}

/* Info bar */
.sample-info {
  flex-shrink: 0;
  padding: 0.75rem 1.25rem 0.6rem;
  border-bottom: 1px solid var(--border);
  background: var(--panel);
}

#infoTitle {
  font-family: var(--font-mono);
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--text);
  margin: 0 0 0.3rem;
}

.info-links {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.75rem;
  flex-wrap: wrap;
  margin-bottom: 0.4rem;
}
.info-links a { color: var(--orange-light); }
.info-links a:hover { color: var(--orange); text-decoration: underline; }
.sep { color: var(--border); }

#infoDesc {
  font-size: 0.78rem;
  color: var(--muted);
  line-height: 1.6;
  margin: 0;
  font-family: var(--font-sans);
}

/* Frame */
.frame-wrap {
  flex: 1;
  padding: 1rem 1.25rem;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.frame-border {
  flex: 1;
  position: relative;
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
  background: #000;
  min-height: 0;
}

#sampleFrame {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: none;
  display: block;
}

/* Overlays */
.overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.6rem;
  background: #0a0a0a;
  font-family: var(--font-mono);
  font-size: 0.78rem;
  color: var(--muted);
  text-align: center;
  padding: 2rem;
}
.overlay[hidden] { display: none; }

.spinner {
  width: 24px;
  height: 24px;
  border: 2px solid var(--border);
  border-top-color: var(--orange);
  border-radius: 50%;
  animation: spin 0.75s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

.warn-icon { font-size: 1.5rem; color: var(--orange-dark); }
.overlay p { margin: 0; line-height: 1.6; }
.overlay .hint { font-size: 0.72rem; margin-top: 0.25rem !important; }

/* Mobile overlay backdrop */
.panel-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 39;
  background: rgba(0,0,0,0.6);
}
.panel-overlay.visible { display: block; }

/* ── Responsive ─────────────────────────────────────────────────────── */
@media (max-width: 720px) {
  .shell { height: calc(100vh - 60px); }

  .panel {
    position: fixed;
    top: 60px;
    left: 0;
    bottom: 0;
    z-index: 40;
    width: min(290px, 86vw);
    transform: translateX(-100%);
    transition: transform 0.22s ease;
    box-shadow: 4px 0 24px rgba(0,0,0,0.4);
  }
  .panel.open { transform: translateX(0); }

  .panel-close {
    display: block;
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--muted);
    font-size: 0.75rem;
    padding: 2px 7px;
    cursor: pointer;
    font-family: var(--font-mono);
  }

  .mobile-header { display: flex; }

  .frame-wrap { padding: 0.6rem; }
  .sample-info { padding: 0.6rem 0.75rem 0.5rem; }
}
</style>

<script is:inline define:vars={{ catalogJSON, groupsJSON, DEFAULT_SAMPLE_SLUG }}>
const catalog = JSON.parse(catalogJSON);

// ── DOM ────────────────────────────────────────────────────────────────
const panel          = document.getElementById('panel');
const panelOverlay   = document.getElementById('panelOverlay');
const panelClose     = document.getElementById('panelClose');
const menuBtn        = document.getElementById('menuBtn');
const welcome        = document.getElementById('welcome');
const sampleView     = document.getElementById('sampleView');
const sampleFrame    = document.getElementById('sampleFrame');
const overlayLoading = document.getElementById('overlayLoading');
const overlayUnavail = document.getElementById('overlayUnavail');
const infoTitle      = document.getElementById('infoTitle');
const infoDesc       = document.getElementById('infoDesc');
const srcLink        = document.getElementById('srcLink');
const standaloneLink = document.getElementById('standaloneLink');
const reportLink     = document.getElementById('reportLink');
const mobileName     = document.getElementById('mobileName');
const searchInput    = document.getElementById('searchInput');
const noResults      = document.getElementById('noResults');

// ── Mobile sidebar ─────────────────────────────────────────────────────
function openPanel() {
  panel.classList.add('open');
  panelOverlay.classList.add('visible');
  document.body.style.overflow = 'hidden';
}
function closePanel() {
  panel.classList.remove('open');
  panelOverlay.classList.remove('visible');
  document.body.style.overflow = '';
}
menuBtn?.addEventListener('click', openPanel);
panelClose?.addEventListener('click', closePanel);
panelOverlay?.addEventListener('click', closePanel);

// ── Search / filter ────────────────────────────────────────────────────
searchInput?.addEventListener('input', () => {
  const q = searchInput.value.trim().toLowerCase();
  let anyVisible = false;

  document.querySelectorAll('.group').forEach(groupEl => {
    const links = groupEl.querySelectorAll('.sample-link');
    let groupVisible = false;
    links.forEach(link => {
      const match = !q || link.textContent.toLowerCase().includes(q);
      link.parentElement.hidden = !match;
      if (match) groupVisible = true;
    });
    groupEl.hidden = !groupVisible;
    if (groupVisible) anyVisible = true;
  });

  noResults.hidden = anyVisible;
});

// ── Sample selection ───────────────────────────────────────────────────
function selectSample(slug) {
  const s = catalog.find(x => x.slug === slug);
  if (!s) return;

  if (window.location.hash !== `#${slug}`) {
    history.pushState(null, '', `#${slug}`);
  }

  // Sidebar active state
  document.querySelectorAll('.sample-link').forEach(el => {
    el.classList.toggle('active', el.dataset.slug === slug);
  });

  // Info bar
  infoTitle.textContent   = s.title;
  infoDesc.textContent    = s.description;
  mobileName.textContent  = s.title;

  // Links
  const wasmPath = `/samples/wasm/${s.target}/${s.target}.html`;
  standaloneLink.href = wasmPath;

  srcLink.href = `https://github.com/vertexnova/vnerhi/tree/main/samples/${s.target}`;

  const issueUrl = new URL('https://github.com/vertexnova/vertexnova.github.io/issues/new');
  issueUrl.searchParams.set('template', 'webgpu-sample-bug.yml');
  issueUrl.searchParams.set('title', `[WebGPU Sample] ${s.title}`);
  reportLink.href = issueUrl.toString();

  // Show sample view
  welcome.style.display   = 'none';
  sampleView.hidden       = false;

  // Reset frame state
  overlayLoading.hidden   = false;
  overlayUnavail.hidden   = true;
  sampleFrame.src         = '';

  requestAnimationFrame(() => { sampleFrame.src = wasmPath; });

  closePanel();
}

sampleFrame?.addEventListener('load', () => {
  overlayLoading.hidden = true;
  try {
    const doc = sampleFrame.contentDocument;
    if (doc && doc.title === '' && doc.body?.children.length === 0) {
      overlayUnavail.hidden = false;
    }
  } catch (_) { /* cross-origin — trust the load */ }
});

sampleFrame?.addEventListener('error', () => {
  overlayLoading.hidden = true;
  overlayUnavail.hidden = false;
});

// ── Nav link clicks ────────────────────────────────────────────────────
document.querySelectorAll('.sample-link').forEach(el => {
  el.addEventListener('click', e => {
    e.preventDefault();
    selectSample(el.dataset.slug);
  });
});

// ── Hash routing ───────────────────────────────────────────────────────
function handleHash() {
  const slug = window.location.hash.slice(1) || DEFAULT_SAMPLE_SLUG;
  selectSample(slug);
}
window.addEventListener('popstate', handleHash);
handleHash();
</script>
