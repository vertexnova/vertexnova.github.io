---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('setup');
const complete = guides.filter(g => g.data.status === 'complete');
const drafts = guides.filter(g => g.data.status === 'draft');
const sorted = [...complete, ...drafts];
---
<BaseLayout title="Setup guides" description="Installation guides and dev environment setup for DGX Spark, gsplat, Docker, and VertexNova.">

<section class="section">
  <div class="container">
    <PageHeader
      eyebrow="Setup guides"
      title="Dev environment setup"
      description="Installation guides for the DGX Spark, Docker containers, gsplat, CUDA, and the VertexNova build environment. Step-by-step with real terminal output."
    />

    <div class="guide-list">
      {sorted.map(g => (
        <a href={`/setup/${g.id}`} class={`guide-card card ${g.data.status === 'draft' ? 'draft' : ''}`}>
          <div class="guide-meta">
            <span class="guide-date">{g.data.date}</span>
            {g.data.status === 'draft' && <span class="tag" style="font-size:0.68rem">coming soon</span>}
            {g.data.status === 'complete' && <span class="tag orange" style="font-size:0.68rem">complete</span>}
          </div>
          <h3 class="guide-title">{g.data.title}</h3>
          <p class="guide-desc">{g.data.description}</p>
          <div class="guide-tags">
            {g.data.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </a>
      ))}
    </div>

    <a href="/setup/docker-reference" class="guide-card card">
      <div class="guide-meta">
        <span class="guide-date">Apr 25, 2026</span>
        <span class="tag orange" style="font-size:0.68rem">reference</span>
      </div>
      <h3 class="guide-title">Docker reference</h3>
      <p class="guide-desc">Docker working knowledge for DGX Spark — concepts, commands, your containers. Interactive tabbed reference.</p>
      <div class="guide-tags">
        <span class="tag">Docker</span>
        <span class="tag">DGX Spark</span>
        <span class="tag">NVIDIA containers</span>
      </div>
    </a>
  </div>
</section>

</BaseLayout>

<style>
.guide-list { display: flex; flex-direction: column; gap: 1rem; margin-top: 3rem; }
.guide-card { display: block; text-decoration: none; }
.guide-card.draft { opacity: 0.55; pointer-events: none; }
.guide-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
.guide-date { font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted); }
.guide-title { color: var(--text); margin-bottom: 0.5rem; font-size: 1.1rem; }
.guide-desc { font-size: 0.9rem; margin-bottom: 1rem; }
.guide-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
</style>
