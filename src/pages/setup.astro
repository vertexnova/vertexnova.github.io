---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

/** Order: primary workflow first, command reference second */
const guides = [
  {
    href: '/setup/dgx-containers',
    step: '1',
    label: 'Primary guide',
    title: 'DGX Containers',
    description:
      'Prerequisites, standard run flags, gsplat-spark and aiml-spark images, verification, and a short compatibility table for GB10.',
    tags: ['DGX Spark', 'Docker', 'gsplat', 'PyTorch'],
  },
  {
    href: '/setup/docker-reference',
    step: '2',
    label: 'Reference',
    title: 'Docker on Spark',
    description:
      'Tabbed lookup: concepts, inspect, run, images, cleanup, and DGX-specific commands. Use alongside the primary guide.',
    tags: ['Docker', 'CLI', 'DGX Spark'],
  },
] as const;
---
<BaseLayout title="Setup" description="DGX Spark setup: container images and Docker command reference for VertexNova.">

<section class="section">
  <div class="container">
    <PageHeader
      eyebrow="Setup"
      title="DGX Spark setup"
      description="Two pages cover this workflow: build and run VertexNova containers on the machine, then keep the Docker reference open when you need exact commands."
    />

    <p class="setup-intro">
      <strong>Reading order:</strong> open <strong>DGX Containers</strong> first. Use <strong>Docker on Spark</strong> when you need a command or pattern without scrolling the full guide.
    </p>

    <h2 class="section-label">Guides</h2>
    <div class="guide-list">
      {guides.map(g => (
        <a href={g.href} class="guide-card card">
          <div class="guide-meta">
            <span class="guide-step">Step {g.step}</span>
            <span class="tag orange" style="font-size:0.68rem">{g.label}</span>
          </div>
          <h3 class="guide-title">{g.title}</h3>
          <p class="guide-desc">{g.description}</p>
          <div class="guide-tags">
            {g.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

</BaseLayout>

<style>
.setup-intro {
  max-width: 720px;
  margin-top: 1.5rem;
  font-size: 0.95rem;
  color: var(--muted);
  line-height: 1.75;
}
.setup-intro strong { color: var(--text); font-weight: 600; }

.section-label {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--orange-light);
  margin-top: 2.5rem;
  margin-bottom: 0.75rem;
  padding-bottom: 0.35rem;
  border-bottom: 1px solid var(--border);
}

.guide-list { display: flex; flex-direction: column; gap: 1rem; }
.guide-card { display: block; text-decoration: none; }
.guide-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
.guide-step { font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted); }
.guide-title { color: var(--text); margin-bottom: 0.5rem; font-size: 1.1rem; }
.guide-desc { font-size: 0.9rem; margin-bottom: 1rem; color: var(--muted); line-height: 1.65; }
.guide-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
</style>
