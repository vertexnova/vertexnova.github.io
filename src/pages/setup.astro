---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const guides = [
  {
    slug: 'dgx-spark-setup',
    title: 'DGX Spark — full dev environment setup',
    date: 'Apr 24, 2026',
    tags: ['DGX Spark', 'Ubuntu 24.04', 'CUDA 13'],
    desc: 'Initial setup of the NVIDIA GB10 Grace Blackwell personal AI supercomputer. Swap disable, Docker flags, workspace structure, and GPU verification.',
    status: 'complete',
  },
  {
    slug: 'gsplat-install',
    title: 'Installing gsplat on DGX Spark (ARM64)',
    date: 'Apr 24, 2026',
    tags: ['gsplat', 'ARM64', 'PyTorch', '3DGS'],
    desc: 'Step-by-step guide to building gsplat 1.5.3 from source on the GB10 Blackwell with CUDA 13 and PyTorch 2.7. Covers the CUDA arch SM 12.0 gotcha.',
    status: 'complete',
  },
  {
    slug: 'docker-containers',
    title: 'Docker container strategy for AI/ML on DGX Spark',
    date: 'Apr 24, 2026',
    tags: ['Docker', 'NVIDIA containers', 'workflow'],
    desc: 'Container naming convention, required run flags, and the two-layer host/container strategy for keeping the DGX OS clean.',
    status: 'complete',
  },
  {
    slug: 'aiml-container',
    title: 'Building the full AI/ML container (PyTorch + TF + OpenCV)',
    date: 'Coming soon',
    tags: ['PyTorch', 'TensorFlow', 'Keras', 'OpenCV'],
    desc: 'Building ajeet/aiml-spark:v1 — the general-purpose AI/ML container with all frameworks properly configured for ARM64 + CUDA 13.',
    status: 'draft',
  },
];
---
<BaseLayout title="Setup guides" description="Installation guides and dev environment setup for DGX Spark, gsplat, Docker, and VertexNova.">

<section class="section">
  <div class="container">
    <PageHeader
      eyebrow="Setup guides"
      title="Dev environment setup"
      description="Installation guides for the DGX Spark, Docker containers, gsplat, CUDA, and the VertexNova build environment. Step-by-step with real terminal output."
    />

    <div class="guide-list">
      {guides.map(g => (
        <div class={`guide-card card ${g.status === 'draft' ? 'draft' : ''}`}>
          <div class="guide-meta">
            <span class="guide-date">{g.date}</span>
            {g.status === 'draft' && <span class="tag" style="font-size:0.68rem">coming soon</span>}
            {g.status === 'complete' && <span class="tag orange" style="font-size:0.68rem">complete</span>}
          </div>
          <h3 class="guide-title">{g.title}</h3>
          <p class="guide-desc">{g.desc}</p>
          <div class="guide-tags">
            {g.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

</BaseLayout>

<style>
.guide-list { display: flex; flex-direction: column; gap: 1rem; margin-top: 3rem; }
.guide-card { cursor: default; }
.guide-card.draft { opacity: 0.55; }
.guide-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
.guide-date { font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted); }
.guide-title { color: var(--text); margin-bottom: 0.5rem; font-size: 1.1rem; }
.guide-desc { font-size: 0.9rem; margin-bottom: 1rem; }
.guide-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
</style>
