---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('setup');
const byId = new Map(guides.map(g => [g.id, g]));

type SectionKey =
  | 'dgx-spark-setup'
  | 'docker-containers'
  | '__docker_reference__'
  | '__dgx_containers__'
  | 'gsplat-install'
  | 'aiml-container';

const sections: { label: string; keys: SectionKey[] }[] = [
  { label: '1 · Host and workspace', keys: ['dgx-spark-setup'] },
  { label: '2 · Containers and workflow', keys: ['docker-containers', '__docker_reference__', '__dgx_containers__'] },
  { label: '3 · Builds and planned images', keys: ['gsplat-install', 'aiml-container'] },
];
---
<BaseLayout title="Setup guides" description="DGX Spark setup, Docker workflow, gsplat, and VertexNova development environment.">

<section class="section">
  <div class="container">
    <PageHeader
      eyebrow="Setup guides"
      title="Development environment"
      description="Follow these guides in order when you are new to the machine. Each page ends with a short checklist you can reuse as class notes."
    />

    <p class="setup-intro">
      <strong>Suggested path:</strong> configure the host, adopt a container workflow, keep the command reference open while you work, then build gsplat and extend the image stack when ready.
    </p>

    {sections.map(sec => (
      <>
        <h2 class="section-label">{sec.label}</h2>
        <div class="guide-list">
          {sec.keys.map(key => {
            if (key === '__docker_reference__') {
              return (
                <a href="/setup/docker-reference" class="guide-card card">
                  <div class="guide-meta">
                    <span class="guide-date">Reference</span>
                    <span class="tag orange" style="font-size:0.68rem">lookup</span>
                  </div>
                  <h3 class="guide-title">Docker command reference</h3>
                  <p class="guide-desc">Tabbed lookup for inspect, run, images, cleanup, and DGX-specific examples. Use it next to the workflow guide.</p>
                  <div class="guide-tags">
                    <span class="tag">Docker</span>
                    <span class="tag">DGX Spark</span>
                    <span class="tag">Commands</span>
                  </div>
                </a>
              );
            }
            if (key === '__dgx_containers__') {
              return (
                <a href="/setup/dgx-containers" class="guide-card card">
                  <div class="guide-meta">
                    <span class="guide-date">Apr 2026</span>
                    <span class="tag orange" style="font-size:0.68rem">deep dive</span>
                  </div>
                  <h3 class="guide-title">DGX Spark — container setup (gsplat and aiml)</h3>
                  <p class="guide-desc">Step-by-step tabbed guide: prerequisites, building vertexnova/gsplat-spark and aiml-spark images, verification, and driver specs for GB10.</p>
                  <div class="guide-tags">
                    <span class="tag">DGX Spark</span>
                    <span class="tag">Images</span>
                    <span class="tag">GB10</span>
                  </div>
                </a>
              );
            }
            const g = byId.get(key);
            if (!g) return null;
            return (
              <a href={`/setup/${g.id}`} class={`guide-card card ${g.data.status === 'draft' ? 'draft' : ''}`}>
                <div class="guide-meta">
                  <span class="guide-date">{g.data.date}</span>
                  {g.data.status === 'draft' && <span class="tag" style="font-size:0.68rem">planned</span>}
                  {g.data.status === 'complete' && <span class="tag orange" style="font-size:0.68rem">complete</span>}
                </div>
                <h3 class="guide-title">{g.data.title}</h3>
                <p class="guide-desc">{g.data.description}</p>
                <div class="guide-tags">
                  {g.data.tags.map(t => <span class="tag">{t}</span>)}
                </div>
              </a>
            );
          })}
        </div>
      </>
    ))}
  </div>
</section>

</BaseLayout>

<style>
.setup-intro {
  max-width: 720px;
  margin-top: 1.5rem;
  font-size: 0.95rem;
  color: var(--muted);
  line-height: 1.75;
}
.setup-intro strong { color: var(--text); font-weight: 600; }

.section-label {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--orange-light);
  margin-top: 2.75rem;
  margin-bottom: 0.75rem;
  padding-bottom: 0.35rem;
  border-bottom: 1px solid var(--border);
}
.section-label:first-of-type { margin-top: 2.5rem; }

.guide-list { display: flex; flex-direction: column; gap: 1rem; }
.guide-card { display: block; text-decoration: none; }
.guide-card.draft { opacity: 0.55; pointer-events: none; }
.guide-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
.guide-date { font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted); }
.guide-title { color: var(--text); margin-bottom: 0.5rem; font-size: 1.1rem; }
.guide-desc { font-size: 0.9rem; margin-bottom: 1rem; color: var(--muted); line-height: 1.65; }
.guide-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
</style>
