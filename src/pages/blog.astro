---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="Blog" description="Technical devlog — DGX Spark experiments, rendering discoveries, and weekly notes.">

<section class="section">
  <div class="container">
    <PageHeader
      eyebrow="Devlog"
      title="Blog & experiments"
      description="Weekly notes on rendering experiments, DGX Spark findings, 3DGS progress, and the journey toward NVIDIA."
    />

    <div class="posts-list">
      {posts.map(p => (
        <a href={`/blog/${p.id}`} class="post-card card">
          <div class="post-meta">
            <span class="post-date">{p.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            <span class="tag orange" style="font-size:0.68rem">{p.data.status}</span>
          </div>
          <h2 class="post-title">{p.data.title}</h2>
          <p class="post-desc">{p.data.description}</p>
          <div class="post-tags">
            {p.data.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

</BaseLayout>

<style>
.posts-list { display: flex; flex-direction: column; gap: 1rem; margin-top: 3rem; }
.post-card { display: block; text-decoration: none; }
.post-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
.post-date { font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted); }
.post-title { color: var(--text); margin-bottom: 0.5rem; font-size: 1.2rem; font-weight: 500; }
.post-desc { font-size: 0.9rem; margin-bottom: 1rem; }
.post-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
</style>
