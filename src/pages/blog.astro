---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const posts = [
  {
    title: 'Weekend goal: first 3DGS renderer on DGX Spark',
    date: 'Apr 25, 2026',
    tags: ['3DGS', 'gsplat', 'DGX Spark', 'weekend'],
    desc: 'Installing gsplat on the GB10, fighting the CUDA 12 vs 13 ecosystem fragility, and the plan to get first Gaussian splats rendering in VertexNova.',
    status: 'published',
  },
  {
    title: 'Gap analysis: what I need to land a role at NVIDIA',
    date: 'Apr 24, 2026',
    tags: ['NVIDIA', 'career', 'Vulkan', '3DGS'],
    desc: 'Honest self-assessment of gaps between my current skill set and what NVIDIA\'s Omniverse and neural graphics teams actually need.',
    status: 'published',
  },
  {
    title: 'Building the VertexNova GitHub Pages site with Astro',
    date: 'Apr 24, 2026',
    tags: ['Astro', 'GitHub Pages', 'meta'],
    desc: 'Setting up this site — Astro, VertexNova visual style guide, structure planning, and the deploy workflow.',
    status: 'published',
  },
];
---
<BaseLayout title="Blog" description="Technical devlog — DGX Spark experiments, rendering discoveries, and weekly notes.">

<section class="section">
  <div class="container">
    <PageHeader
      eyebrow="Devlog"
      title="Blog & experiments"
      description="Weekly notes on rendering experiments, DGX Spark findings, 3DGS progress, and the journey toward NVIDIA."
    />

    <div class="posts-list" style="margin-top:3rem">
      {posts.map(p => (
        <article class="post-card card">
          <div class="post-meta">
            <span class="post-date">{p.date}</span>
            <span class="tag orange" style="font-size:0.68rem">{p.status}</span>
          </div>
          <h2 class="post-title">{p.title}</h2>
          <p class="post-desc">{p.desc}</p>
          <div class="post-tags">
            {p.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

</BaseLayout>

<style>
.posts-list { display: flex; flex-direction: column; gap: 1rem; }
.post-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
.post-date { font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted); }
.post-title { color: var(--text); margin-bottom: 0.5rem; font-size: 1.2rem; font-weight: 500; }
.post-desc { font-size: 0.9rem; margin-bottom: 1rem; }
.post-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
</style>
