---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About" description="Ajeet Yadav — Principal Engineer, real-time 3D graphics, surgical robotics, VertexNova creator.">

<section class="section">
  <div class="container">
    <div class="about-header">
      <div class="avatar">AY</div>
      <div>
        <span class="tag orange">Principal Engineer · Stryker</span>
        <h1 style="margin-top:0.75rem">Ajeet Yadav</h1>
        <p class="location">Weston, Florida</p>
      </div>
    </div>

    <div class="about-grid">
      <div class="about-main">
        <p class="lead">
          Principal Engineer with 10+ years in surgical robotics, with deep focus on real-time 3D graphics
          and rendering architecture since 2021. Component lead for Stryker's Mako visualization stack —
          the rendering system used live in the operating room during robotic surgery.
        </p>

        <h2>Experience</h2>
        <div class="exp-list">
          <div class="exp-item">
            <div class="exp-header">
              <span class="exp-company">Stryker</span>
              <span class="exp-date">Sep 2025 – Present</span>
            </div>
            <span class="exp-role">Principal Engineer — 3D Visualization Component Lead</span>
            <p>Component lead for Stryker's 3D visualization library. Owns architecture, roadmap, and quality of the rendering stack across multiple surgical robotic applications.</p>
          </div>
          <div class="exp-item">
            <div class="exp-header">
              <span class="exp-company">Stryker</span>
              <span class="exp-date">Mar 2022 – Aug 2025</span>
            </div>
            <span class="exp-role">Senior Staff Engineer — Real-Time Rendering & Visualization</span>
            <p>Architected the real-time visualization library for the Mako robotic surgery platform. OIT, CSG, picking, mesh visualization, surgical planning overlays used live in the OR.</p>
          </div>
          <div class="exp-item">
            <div class="exp-header">
              <span class="exp-company">Stryker</span>
              <span class="exp-date">Aug 2016 – Feb 2022</span>
            </div>
            <span class="exp-role">Staff Engineer / Senior Software Engineer</span>
            <p>Robotics software, algorithm development, implant planning, bone resection workflows. Founded robe.ai — internal AI/ML group applying deep learning to spine segmentation.</p>
          </div>
          <div class="exp-item">
            <div class="exp-header">
              <span class="exp-company">Tata Consultancy Services</span>
              <span class="exp-date">Mar 2011 – Jul 2014</span>
            </div>
            <span class="exp-role">Systems Engineer</span>
            <p>Automotive embedded systems — Body Electronics, MATLAB Simulink/Stateflow, TPMS, Wiper-Washer systems.</p>
          </div>
        </div>

        <h2>Patents</h2>
        <div class="patent-list">
          <div class="patent-item">
            <code>US20220183757A1</code>
            <span>Surgeon Preferences and Warning Visualizations for Implant Planning</span>
          </div>
          <div class="patent-item">
            <code>WO2024006451A1</code>
            <span>Robotic Surgery System with Plan-Dependent Surgical Visualization</span>
          </div>
        </div>
      </div>

      <div class="about-sidebar">
        <div class="card sidebar-card">
          <h3>Skills</h3>
          <div class="skill-group">
            <span class="skill-label">Graphics</span>
            <div class="skill-tags">
              <span class="tag">OpenGL 4.5</span>
              <span class="tag">ES 3.0</span>
              <span class="tag">Vulkan</span>
              <span class="tag">Metal</span>
            </div>
          </div>
          <div class="skill-group">
            <span class="skill-label">Languages</span>
            <div class="skill-tags">
              <span class="tag">C++20</span>
              <span class="tag">Python</span>
              <span class="tag">GLSL</span>
            </div>
          </div>
          <div class="skill-group">
            <span class="skill-label">Rendering</span>
            <div class="skill-tags">
              <span class="tag">OIT</span>
              <span class="tag">CSG</span>
              <span class="tag">3DGS</span>
              <span class="tag">Picking</span>
            </div>
          </div>
          <div class="skill-group">
            <span class="skill-label">Tools</span>
            <div class="skill-tags">
              <span class="tag">SPIRV-Cross</span>
              <span class="tag">CMake</span>
              <span class="tag">ECS</span>
              <span class="tag">Qt</span>
            </div>
          </div>
          <div class="skill-group">
            <span class="skill-label">AI / ML</span>
            <div class="skill-tags">
              <span class="tag">PyTorch</span>
              <span class="tag">TensorFlow</span>
              <span class="tag">OpenCV</span>
              <span class="tag">gsplat</span>
            </div>
          </div>
        </div>

        <div class="card sidebar-card">
          <h3>Education</h3>
          <div class="edu-item">
            <span class="edu-school">IIT Kanpur</span>
            <span class="edu-degree">M.Tech — Signal Processing</span>
            <span class="edu-gpa">GPA 8.75 / 10</span>
          </div>
          <div class="edu-item">
            <span class="edu-school">UPTU Lucknow</span>
            <span class="edu-degree">B.Tech — Electronics & Communication</span>
          </div>
        </div>

        <div class="card sidebar-card">
          <h3>Connect</h3>
          <div class="connect-links">
            <a href="https://linkedin.com/in/ajeet-yadav-b1133991" target="_blank" class="connect-link">LinkedIn ↗</a>
            <a href="https://github.com/ajeetsinghyadav" target="_blank" class="connect-link">GitHub (personal) ↗</a>
            <a href="https://github.com/vertexnova" target="_blank" class="connect-link">GitHub (VertexNova) ↗</a>
            <a href="https://learnvertexnova.com" target="_blank" class="connect-link">learnvertexnova.com ↗</a>
            <a href="mailto:yadav.ajeetsingh2020@gmail.com" class="connect-link">Email ↗</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
.about-header { display: flex; align-items: center; gap: 1.5rem; margin-bottom: 3rem; }
.avatar { width: 64px; height: 64px; border-radius: 50%; background: var(--orange-tint); border: 2px solid var(--orange-dark); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; font-weight: 600; color: var(--orange-light); flex-shrink: 0; }
.location { font-size: 0.85rem; color: var(--muted); margin-top: 0.25rem; font-family: var(--font-mono); }
.about-grid { display: grid; grid-template-columns: 1fr 320px; gap: 3rem; align-items: start; }
.lead { font-size: 1.05rem; color: var(--muted); margin-bottom: 2.5rem; line-height: 1.8; }
.about-main h2 { margin-top: 2.5rem; margin-bottom: 1.25rem; }
.exp-list { display: flex; flex-direction: column; gap: 1.25rem; }
.exp-item { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; }
.exp-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem; }
.exp-company { font-weight: 600; color: var(--text); font-size: 0.95rem; }
.exp-date { font-family: var(--font-mono); font-size: 0.75rem; color: var(--muted); }
.exp-role { display: block; color: var(--orange-light); font-size: 0.88rem; margin-bottom: 0.5rem; }
.exp-item p { font-size: 0.85rem; }
.patent-list { display: flex; flex-direction: column; gap: 0.75rem; }
.patent-item { display: flex; align-items: baseline; gap: 0.75rem; padding: 0.75rem 1rem; background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius); }
.patent-item code { flex-shrink: 0; font-size: 0.78rem; }
.patent-item span { font-size: 0.88rem; color: var(--muted); }
.sidebar-card { margin-bottom: 1rem; }
.sidebar-card h3 { margin-bottom: 1rem; font-size: 0.9rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }
.skill-group { margin-bottom: 0.75rem; }
.skill-label { font-size: 0.75rem; color: var(--muted); display: block; margin-bottom: 0.35rem; }
.skill-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
.edu-item { margin-bottom: 1rem; }
.edu-school { font-weight: 500; color: var(--text); font-size: 0.9rem; display: block; }
.edu-degree { font-size: 0.82rem; color: var(--muted); display: block; }
.edu-gpa { font-size: 0.78rem; color: var(--orange-light); font-family: var(--font-mono); display: block; margin-top: 2px; }
.connect-links { display: flex; flex-direction: column; gap: 0.5rem; }
.connect-link { font-size: 0.85rem; color: var(--orange-light); }
.connect-link:hover { color: var(--orange); }
@media (max-width: 900px) {
  .about-grid { grid-template-columns: 1fr; }
  .about-sidebar { order: -1; }
}
</style>
