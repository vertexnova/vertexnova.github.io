---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  maxWidth?: string;
}

const { eyebrow, title, description, maxWidth = '600px' } = Astro.props;
---

<div class="page-header">
  <span class="tag orange">{eyebrow}</span>
  <h1>{title}</h1>
  <p style={`max-width:${maxWidth}`}>{description}</p>
  <slot name="actions" />
</div>

<style>
.page-header h1 {
  margin-top: 1rem;
}

.page-header p {
  color: var(--muted);
  font-size: 1.05rem;
  margin-top: 0.75rem;
}
</style>
