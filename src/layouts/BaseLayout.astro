---
import '../styles/global.css';
const { title = 'VertexNova', description = 'Multi-backend 3D rendering engine and AI dev workspace by Ajeet Yadav.' } = Astro.props;
const path = Astro.url.pathname;
const nav = [
  { href: '/',          label: 'Home' },
  { href: '/engine',    label: 'Engine'   },
  { href: '/setup',     label: 'Setup'    },
  { href: '/research',  label: 'Research' },
  { href: '/blog',      label: 'Blog'     },
  { href: '/about',     label: 'About'    },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | VertexNova</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <img src="/favicon.svg" alt="VertexNova logo" class="logo-mark" />
      <span class="logo-text">VertexNova</span>
    </a>
    <nav class="site-nav">
      {nav.map(n => (
        <a href={n.href} class={`nav-link ${path === n.href || (n.href !== '/' && path.startsWith(n.href)) ? 'active' : ''}`}>
          {n.label}
        </a>
      ))}
    </nav>
    <a href="https://github.com/vertexnova" target="_blank" class="btn btn-ghost btn-sm">
      GitHub ↗
    </a>
  </div>
</header>

<main>
  <slot />
</main>

<footer class="site-footer">
  <div class="divider"></div>
  <div class="container footer-inner">
    <div class="footer-left">
      <a href="/" class="logo">
        <img src="/favicon.svg" alt="VertexNova logo" class="logo-mark logo-mark-sm" />
        <span class="logo-text" style="font-size:0.9rem">VertexNova</span>
      </a>
      <p style="margin-top:0.4rem;font-size:0.8rem">Multi-backend 3D rendering engine. Built by Ajeet Yadav.</p>
    </div>
    <div class="footer-links">
      <div>
        <span class="footer-col-title">Project</span>
        <a href="https://github.com/vertexnova" target="_blank">GitHub</a>
        <a href="https://learnvertexnova.com" target="_blank">Docs site</a>
        <a href="/engine">Engine</a>
      </div>
      <div>
        <span class="footer-col-title">Content</span>
        <a href="/setup">Setup guides</a>
        <a href="/research">Research</a>
        <a href="/blog">Blog</a>
      </div>
      <div>
        <span class="footer-col-title">Connect</span>
        <a href="https://linkedin.com/in/ajeet-yadav-b1133991" target="_blank">LinkedIn</a>
        <a href="https://github.com/ajeetsinghyadav" target="_blank">GitHub</a>
        <a href="/about">About</a>
      </div>
    </div>
  </div>
  <div class="container" style="padding-top:1.5rem;padding-bottom:1.5rem;border-top:1px solid var(--border);margin-top:2rem">
    <p style="font-size:0.78rem;color:var(--muted);text-align:center">© 2026 VertexNova · Ajeet Yadav · H-1B valid through Oct 2027</p>
  </div>
</footer>

</body>
</html>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(28,28,30,0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}
.header-inner {
  display: flex;
  align-items: center;
  gap: 2rem;
  height: 60px;
}
.logo {
  display: flex;
  align-items: center;
  gap: 8px;
  text-decoration: none;
  flex-shrink: 0;
}
.logo-mark {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
}
.logo-mark-sm { width: 16px; height: 16px; }
.logo-text {
  font-size: 1rem;
  font-weight: 600;
  color: var(--text);
  letter-spacing: -0.01em;
}
.site-nav {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  flex: 1;
}
.nav-link {
  font-size: 0.875rem;
  color: var(--muted);
  padding: 6px 12px;
  border-radius: 6px;
  transition: all 0.15s;
  text-decoration: none;
}
.nav-link:hover { color: var(--text); background: var(--panel); }
.nav-link.active { color: var(--orange-light); background: var(--orange-tint); }
.btn-sm { padding: 6px 14px; font-size: 0.8rem; }

.site-footer { padding-top: 3rem; }
.footer-inner {
  display: flex;
  gap: 3rem;
  padding-bottom: 2rem;
}
.footer-left { flex: 1; }
.footer-links { display: flex; gap: 3rem; }
.footer-links div { display: flex; flex-direction: column; gap: 0.5rem; }
.footer-col-title {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--text);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 0.25rem;
}
.footer-links a { font-size: 0.85rem; color: var(--muted); }
.footer-links a:hover { color: var(--orange-light); }

@media (max-width: 768px) {
  .site-nav { display: none; }
  .footer-inner { flex-direction: column; }
  .footer-links { flex-wrap: wrap; gap: 2rem; }
}
</style>
