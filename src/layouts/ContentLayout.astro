---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date?: string;
  tags?: string[];
  backHref: string;
  backLabel: string;
  eyebrow?: string;
}

const { title, description, date, tags = [], backHref, backLabel, eyebrow } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <section class="section">
    <div class="container content-container">
      <nav class="breadcrumb">
        <a href={backHref} class="back-link">← {backLabel}</a>
      </nav>

      <header class="content-header">
        {eyebrow && <span class="tag orange">{eyebrow}</span>}
        <h1>{title}</h1>
        <div class="content-meta">
          {date && <span class="content-date">{date}</span>}
          <div class="content-tags">
            {tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
        <p class="content-desc">{description}</p>
      </header>

      <div class="prose">
        <slot />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.content-container { max-width: 820px; }

.breadcrumb { margin-bottom: 2.5rem; }
.back-link { font-size: 0.88rem; color: var(--muted); }
.back-link:hover { color: var(--orange-light); }

.content-header { margin-bottom: 3rem; }
.content-header h1 { margin-top: 1rem; }

.content-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-top: 1rem;
}
.content-date {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  color: var(--muted);
}
.content-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }

.content-desc {
  margin-top: 1.25rem;
  font-size: 1.1rem;
  color: var(--muted);
  max-width: 640px;
  line-height: 1.8;
}

/* Markdown prose styles */
.prose { font-size: 1.05rem; line-height: 1.9; }
.prose h2 { font-size: 1.5rem; margin-top: 2.75rem; margin-bottom: 1rem; }
.prose h3 { font-size: 1.15rem; margin-top: 2rem; margin-bottom: 0.75rem; }
.prose p { margin-bottom: 1.35rem; font-size: inherit; }
.prose ul, .prose ol { margin-bottom: 1.35rem; padding-left: 1.75rem; color: var(--muted); font-size: inherit; }
.prose li { margin-bottom: 0.5rem; line-height: 1.8; }
.prose strong { color: var(--text); }
.prose a { color: var(--orange-light); }
.prose a:hover { color: var(--orange); }
.prose blockquote {
  border-left: 3px solid var(--orange-dark);
  padding: 0.75rem 1.25rem;
  margin: 1.75rem 0;
  background: var(--panel);
  border-radius: 0 var(--radius) var(--radius) 0;
  color: var(--muted);
  font-size: inherit;
}
.prose hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }

/* Code block wrapper with copy button */
.prose .code-block {
  position: relative;
  margin: 1.75rem 0;
}
.prose .code-block pre {
  margin: 0;
  font-size: 0.92rem;
  padding-right: 4rem;
}
.copy-btn {
  position: absolute;
  top: 0.6rem;
  right: 0.6rem;
  background: var(--panel-mid);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--muted);
  font-family: var(--font-mono);
  font-size: 0.7rem;
  padding: 3px 10px;
  cursor: pointer;
  transition: all 0.15s;
  line-height: 1.6;
}
.copy-btn:hover { border-color: var(--orange-dark); color: var(--orange-light); }
.copy-btn.copied { color: #7abf82; border-color: #1a4a20; }
</style>

<script>
document.querySelectorAll('.prose pre').forEach(pre => {
  const wrapper = document.createElement('div');
  wrapper.className = 'code-block';
  pre.parentNode?.insertBefore(wrapper, pre);
  wrapper.appendChild(pre);

  const btn = document.createElement('button');
  btn.className = 'copy-btn';
  btn.textContent = 'copy';
  wrapper.appendChild(btn);

  btn.addEventListener('click', async () => {
    const text = pre.querySelector('code')?.innerText ?? pre.innerText;
    await navigator.clipboard.writeText(text);
    btn.textContent = 'copied!';
    btn.classList.add('copied');
    setTimeout(() => {
      btn.textContent = 'copy';
      btn.classList.remove('copied');
    }, 2000);
  });
});
</script>
