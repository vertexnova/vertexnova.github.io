---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date?: string;
  tags?: string[];
  backHref: string;
  backLabel: string;
  eyebrow?: string;
}

const { title, description, date, tags = [], backHref, backLabel, eyebrow } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <section class="section">
    <div class="container content-container">
      <nav class="breadcrumb">
        <a href={backHref} class="back-link">← {backLabel}</a>
      </nav>

      <header class="content-header">
        {eyebrow && <span class="tag orange">{eyebrow}</span>}
        <h1>{title}</h1>
        <div class="content-meta">
          {date && <span class="content-date">{date}</span>}
          <div class="content-tags">
            {tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
        <p class="content-desc">{description}</p>
      </header>

      <div class="prose">
        <slot />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.content-container { max-width: 780px; }

.breadcrumb { margin-bottom: 2.5rem; }
.back-link { font-size: 0.88rem; color: var(--muted); }
.back-link:hover { color: var(--orange-light); }

.content-header { margin-bottom: 3rem; }
.content-header h1 { margin-top: 1rem; }

.content-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-top: 1rem;
}
.content-date {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  color: var(--muted);
}
.content-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }

.content-desc {
  margin-top: 1.25rem;
  font-size: 1.05rem;
  color: var(--muted);
  max-width: 600px;
}

/* Markdown prose styles */
.prose { line-height: 1.8; }
.prose h2 { margin-top: 2.5rem; margin-bottom: 1rem; }
.prose h3 { margin-top: 2rem; margin-bottom: 0.75rem; }
.prose p { margin-bottom: 1.25rem; }
.prose ul, .prose ol { margin-bottom: 1.25rem; padding-left: 1.5rem; color: var(--muted); }
.prose li { margin-bottom: 0.4rem; }
.prose strong { color: var(--text); }
.prose a { color: var(--orange-light); }
.prose a:hover { color: var(--orange); }
.prose pre { margin: 1.5rem 0; }
.prose blockquote {
  border-left: 3px solid var(--orange-dark);
  padding: 0.75rem 1.25rem;
  margin: 1.5rem 0;
  background: var(--panel);
  border-radius: 0 var(--radius) var(--radius) 0;
  color: var(--muted);
}
.prose hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
</style>
